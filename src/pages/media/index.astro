---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Media',
  description:
    'Publikacje i wystąpienia Wojciecha Tracichleb w mediach — Money.pl, Dobrze Mieszkaj, Coraz Lepsza Firma, Extradom.',
};

const publications = [
  {
    title: '„Zabraknie rąk do pracy? Wielki problem budowlanki"',
    description:
      'Prefabrykacja to będzie przyszłość. Moje myślenie życzeniowe, jako generalnego wykonawcy, jest oczywiście takie, że dobrze by było, gdyby tak nie było… Ale wydaje mi się, że nie ma możliwości, żeby to się nie zmieniło.',
    url: 'https://www.money.pl/gospodarka/zabraknie-rak-do-pracy-wielki-problem-budowlanki-7212489332370400a.html',
    source: 'money.pl',
  },
  {
    title: '„Od marzenia do wprowadzenia" — recenzja książki',
    description:
      'Portal Extradom.pl nawiązał ze mną oficjalną współpracę. Jak napisali: „zdecydowaliśmy się nawiązać współpracę z Panem Wojciechem Tracichlebem, bo wyznajemy te same wartości".',
    url: 'https://www.extradom.pl/porady/artykul-od-marzenia-do-wprowadzenia-wojciech-tracichleb-recenzja-ksiazki',
    source: 'extradom.pl',
  },
  {
    title: 'Fundamentalny Podcast — rozmowa o książce i budowie domu',
    description:
      'W podcaście Extradom opowiadam o tym, jak powstała książka „Od marzenia do wprowadzenia" i dzielę się praktycznymi wskazówkami dla osób planujących budowę własnego domu.',
    url: 'https://open.spotify.com/episode/5KtERj16VHqu2SXYBTf04q?si=h6SK8aqKQ9iL8YE_3gq1LQ',
    source: 'spotify.com',
    youtubeId: 'skQtz9JdeHo',
  },
  {
    title: '„Bez tego nie ruszysz z budową domu. Mało kto o tym wie, ekspert tłumaczy: kluczowe zasady"',
    description:
      'Wytyczenie domu na działce to kluczowy etap przed rozpoczęciem prac budowlanych. Jak wygląda taki proces? Dlaczego jest tak ważny?',
    url: 'https://www.dobrzemieszkaj.pl/najlepsze_domy/domy/331/bez_tego_nie_ruszysz_z_budowa_domu_malo_kto_o_tym_wie_ekspert_tlumaczy_kluczowe_zasady,315667.html',
    source: 'dobrzemieszkaj.pl',
  },
  {
    title: '„Ekspert radzi: Wybór projektu domu krok po kroku. Co musisz wiedzieć, zanim wydasz choćby złotówkę"',
    description:
      'Nie zaczynaj od katalogu, nie sugeruj się tylko wyglądem elewacji. Oto 7 praktycznych wskazówek, dzięki którym wybierzesz najlepszy projekt domu.',
    url: 'https://www.dobrzemieszkaj.pl/najlepsze_domy/domy/331/jak_wybrac_projekt_domu_ekspert_radzi_na_co_zwrocic_uwage,316146.html',
    source: 'dobrzemieszkaj.pl',
  },
  {
    title: '„Kredyt na budowę domu. Ekspert radzi, jak ogarnąć wszystkie formalności"',
    description:
      'Jak przygotować się do kredytu hipotecznego na budowę domu? Co wpływa na zdolność kredytową i jakie dokumenty będą potrzebne?',
    url: 'https://www.dobrzemieszkaj.pl/najlepsze_domy/domy/331/kredyt_na_budowe_domu_ekspert_radzi_jak_ogarnac_wszystkie_formalnosci_to_trzeba_wiedziec,315878.html',
    source: 'dobrzemieszkaj.pl',
  },
  {
    title: '„Konstrukcja dachu. Jakie rozwiązanie wybrać? Ekspert radzi, jak uniknąć błędów na etapie budowy"',
    description:
      'Więźba tradycyjna czy wiązary prefabrykowane? Jakie błędy przy dachu kosztują najwięcej i jak ich uniknąć?',
    url: 'https://www.dobrzemieszkaj.pl/najlepsze_domy/technologie/334/budujesz_dom_ekspert_wyjasnia_jakie_bledy_przy_dachu_kosztuja_najwiecej,317387.html',
    source: 'dobrzemieszkaj.pl',
  },
  {
    title: '„Stolarka w domu. Jak dbać o okna, drzwi, rolety i bramę garażową? Ekspert radzi"',
    description:
      'Jak zadbać o stolarkę w nowym domu? O czym pamiętać przy montażu okien, drzwi i bramy garażowej? Wybrać rolety czy żaluzje fasadowe?',
    url: 'https://www.dobrzemieszkaj.pl/najlepsze_domy/domy/331/stolarka_w_domu_jak_dbac_o_okna_drzwi_rolety_i_brame_garazowa_ekspert_radzi,316541.html',
    source: 'dobrzemieszkaj.pl',
  },
  {
    title: '„Malutkie kroki dają sumarycznie duży efekt. Statek koryguje kurs na bieżąco"',
    description:
      'Rozmowa o prowadzeniu firmy budowlanej, filozofii małych kroków w rozwoju biznesu i specyfice branży. Opowiadam o tym, jak zmieniały się moje priorytety życiowe — od skoków spadochronowych do rodziny i biznesu.',
    url: 'https://www.corazlepszafirma.pl/blog/wojciech-tracichleb-wywiad',
    source: 'corazlepszafirma.pl',
  },
];
---

<Layout metadata={metadata}>
  <Hero tagline="Media">
    <Fragment slot="title">
      Moje <span class="text-accent dark:text-white">publikacje</span>
    </Fragment>

    <Fragment slot="subtitle">
      Dzielę się wiedzą o budowie domów jednorodzinnych nie tylko na tej stronie i w książce. Regularnie udzielam się w
      mediach branżowych — w wywiadach, podcastach i artykułach eksperckich. Poniżej znajdziecie wybrane publikacje.
    </Fragment>
  </Hero>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="space-y-6">
      {
        publications.map((pub) => (
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
            {pub.youtubeId && (
              <div class="aspect-video">
                <iframe
                  src={`https://www.youtube.com/embed/${pub.youtubeId}`}
                  title={pub.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="w-full h-full"
                />
              </div>
            )}
            <a
              href={pub.url}
              target="_blank"
              rel="noopener"
              class="block p-6 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors"
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-lg font-semibold dark:text-white mb-2">{pub.title}</h3>
                  {pub.description && <p class="text-muted text-sm mb-2">{pub.description}</p>}
                  <span class="text-xs font-medium text-primary uppercase tracking-wider">{pub.source}</span>
                </div>
                <svg
                  class="w-5 h-5 text-muted flex-shrink-0 mt-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                  />
                </svg>
              </div>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
