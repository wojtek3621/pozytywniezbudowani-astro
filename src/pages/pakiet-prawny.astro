---
import Layout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';

import wojtekPortret from '~/assets/images/site/wojtek-o-autorze-ksiazka.jpg';
import bookCover from '~/assets/images/ksiazka/book-cover-cta.jpg';

// Landing produktu „Pakiet Prawny Budowy Domu".
// Treść pisana tak, jakby produkt był dostępny (premiera bez daty – strona nie jest
// promowana ani indeksowana do czasu uruchomienia sprzedaży).
//
// STAN PRZEJŚCIOWY: checkout jeszcze nie istnieje, więc KAŻDE CTA prowadzi do /ksiazka/.
// PRZY PREMIERZE: podmień `kupUrl` na URL koszyka SalesCRM (jedyne miejsce do zmiany).
const kupUrl = '/ksiazka/';

// Liczby zgodne z realną zawartością pakietu (builds/pakiet-prawny/):
// 2 umowy + 7 protokołów + 13 pism/druków = 22 wzory; + 3 vademecum + poradnik = 26 plików.
const metadata = {
  title: 'Pakiet Prawny Budowy Domu – 22 wzory dokumentów dla inwestora',
  description:
    'Komplet dokumentów na budowę domu: 2 umowy, 7 protokołów, wezwania i pokwitowania, 3 vademecum i poradnik prawny. Opracowany przez Kancelarię Pewnie, dopilnowany przez praktyka budowlanego. 399 zł.',
  robots: { index: true, follow: true },
};
---

<Layout metadata={metadata}>
  <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css" />

  <div class="pp-page">
    <!-- ===== HERO ===== -->
    <section class="pp-hero">
      <div class="pp-container">
        <div class="pp-hero-grid">
          <div>
            <span class="pp-badge"
              ><i class="fa fa-file-signature" aria-hidden="true"></i> Komplet dokumentów na budowę domu</span
            >
            <h1 class="pp-h1">Pakiet Prawny Budowy Domu</h1>
            <p class="pp-lead">
              26 plików, które zabezpieczają Waszą budowę od pierwszego podpisu do odbioru końcowego: dwie umowy, siedem
              protokołów, wezwania, pokwitowania, trzy vademecum i poradnik prawny. Opracowane przez kancelarię prawną,
              dopilnowane przeze mnie od strony realiów placu budowy.
            </p>
            <p class="pp-lead pp-lead-strong">
              Cel jest jeden: gdyby na Waszej budowie coś poszło nie tak, macie usłyszeć od prawnika zdanie: <em
                >„Jest Pan świetnie przygotowany. Mamy z&nbsp;czym pracować”</em
              >.
            </p>
            <div class="pp-hero-cta">
              <a class="pp-btn" href={kupUrl}>
                <i class="fa fa-lock" aria-hidden="true"></i> Kup Pakiet Prawny – 399 zł
              </a>
              <p class="pp-hero-note">
                <i class="fa fa-undo-alt" aria-hidden="true"></i> 30 dni na zwrot – jeden mail, bez pytań.
              </p>
            </div>
          </div>

          <div>
            <div class="pp-hero-card">
              <div class="pp-hero-card-title"><i class="fa fa-box-open" aria-hidden="true"></i> Co jest w środku</div>
              <ul class="pp-hero-card-list">
                <li>
                  <i class="fa fa-file-signature" aria-hidden="true"></i>
                  <span><strong>22 wzory dokumentów</strong> – 2 umowy, 7 protokołów, 13 pism i&nbsp;druków</span>
                </li>
                <li>
                  <i class="fa fa-book-open" aria-hidden="true"></i>
                  <span><strong>3 vademecum</strong> – umowy objaśnione paragraf po paragrafie, ludzkim językiem</span>
                </li>
                <li>
                  <i class="fa fa-graduation-cap" aria-hidden="true"></i>
                  <span
                    ><strong>Poradnik prawny w 3 częściach</strong> – od podpisania umowy po dochodzenie roszczeń</span
                  >
                </li>
                <li>
                  <i class="fa fa-file-word" aria-hidden="true"></i>
                  <span><strong>Format DOCX</strong> – edytujecie i dostosowujecie do swojej budowy</span>
                </li>
              </ul>
              <div class="pp-hero-card-foot">
                <i class="fa fa-balance-scale" aria-hidden="true"></i>
                Opracowane przez Kancelarię Pewnie (Wrocław)
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PASEK LICZB ===== -->
    <section class="pp-stats-band">
      <div class="pp-container">
        <div class="pp-stats">
          <div class="pp-stat">
            <span class="pp-stat-nr">22</span><span class="pp-stat-label">wzory dokumentów</span>
          </div>
          <div class="pp-stat"><span class="pp-stat-nr">2</span><span class="pp-stat-label">wzory umów</span></div>
          <div class="pp-stat"><span class="pp-stat-nr">7</span><span class="pp-stat-label">protokołów</span></div>
          <div class="pp-stat"><span class="pp-stat-nr">3</span><span class="pp-stat-label">vademecum</span></div>
          <div class="pp-stat">
            <span class="pp-stat-nr">3</span><span class="pp-stat-label">części poradnika</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROBLEM ===== -->
    <section class="pp-section">
      <div class="pp-container">
        <h2 class="pp-h2 pp-center">Trzy sytuacje, które widziałem zbyt wiele razy</h2>
        <p class="pp-sub pp-center">
          Od 2013 roku buduję domy jednorodzinne jako generalny wykonawca. Większość budów kończy się dobrze – ale gdy
          kończy się źle, prawie zawsze zaczyna się od tego samego.
        </p>

        <div class="pp-grid-3">
          <div class="pp-problem">
            <div class="pp-problem-icon"><i class="fa fa-handshake-slash" aria-hidden="true"></i></div>
            <h3>Umowa „na gębę”</h3>
            <p>
              „Panie, po co nam te papierki, ja tak zawsze pracuję.” Dopóki wszystko idzie dobrze – faktycznie po nic.
              Gdy pojawia się problem, zostaje Wasze słowo przeciwko słowu wykonawcy.
            </p>
          </div>
          <div class="pp-problem">
            <div class="pp-problem-icon"><i class="fa fa-money-bill-wave" aria-hidden="true"></i></div>
            <h3>Pieniądze bez pokwitowania</h3>
            <p>
              Zaliczka gotówką, „przecież się znamy”. Bez dowodu wpłaty trudno później udowodnić, ile i za co
              zapłaciliście – nawet jeśli racja jest w stu procentach po Waszej stronie.
            </p>
          </div>
          <div class="pp-problem">
            <div class="pp-problem-icon"><i class="fa fa-clipboard" aria-hidden="true"></i></div>
            <h3>Odbiory bez protokołu</h3>
            <p>
              Etap „odebrany” kiwnięciem głowy i przelewem. Po kilku miesiącach wychodzą wady – a nie ma żadnego
              dokumentu, który potwierdzałby, co i w jakim stanie odebraliście.
            </p>
          </div>
        </div>

        <p class="pp-note pp-center">
          Nie piszę tego, żeby Was straszyć. Dokumenty robi się właśnie na tę mniejszość przypadków, w których coś się
          psuje – tak jak pasy bezpieczeństwa zapina się przed jazdą, a nie przed stłuczką.
        </p>
      </div>
    </section>

    <!-- ===== DWIE ROZMOWY Z PRAWNIKIEM ===== -->
    <section class="pp-section pp-section-cream">
      <div class="pp-container">
        <h2 class="pp-h2 pp-center">Dwie rozmowy z prawnikiem</h2>
        <p class="pp-sub pp-center">
          Tak w praktyce wygląda różnica między budową dokumentowaną a niedokumentowaną, gdy spór staje się realny.
        </p>

        <div class="pp-grid-2">
          <div class="pp-talk pp-talk-bad">
            <div class="pp-talk-head"><i class="fa fa-folder-minus" aria-hidden="true"></i> Bez dokumentacji</div>
            <dl class="pp-talk-dialog">
              <dt>– Ma Pan umowę?</dt>
              <dd>– Nie, umówiliśmy się ustnie.</dd>
              <dt>– Ma Pan pokwitowania wpłat?</dt>
              <dd>– Płaciłem gotówką, bez pokwitowań.</dd>
              <dt>– Protokoły odbioru?</dt>
              <dd>– Mam zdjęcia i wiadomości w telefonie.</dd>
            </dl>
            <p class="pp-talk-verdict">
              „Możemy spróbować, ale dowodów jest niewiele. Będzie trudno i będzie to kosztowało.”
            </p>
          </div>

          <div class="pp-talk pp-talk-good">
            <div class="pp-talk-head"><i class="fa fa-folder-open" aria-hidden="true"></i> Z dokumentacją</div>
            <dl class="pp-talk-dialog">
              <dt>– Ma Pan umowę?</dt>
              <dd>– Tak, z zakresem prac, terminami i harmonogramem.</dd>
              <dt>– Ma Pan pokwitowania wpłat?</dt>
              <dd>– Tak, do każdej wpłaty.</dd>
              <dt>– Protokoły odbioru?</dt>
              <dd>– Z każdego etapu, z podpisami obu stron.</dd>
            </dl>
            <p class="pp-talk-verdict pp-talk-verdict-good">„Jest Pan świetnie przygotowany. Mamy z czym pracować.”</p>
          </div>
        </div>

        <p class="pp-note pp-center">
          Różnica między tymi rozmowami to nie szczęście ani talent – to kilkanaście dokumentów podpisanych we
          właściwych momentach. Dokładnie po to powstał ten pakiet.
        </p>
      </div>
    </section>

    <!-- ===== CO ZNAJDZIECIE W PAKIECIE ===== -->
    <section class="pp-section" id="zawartosc">
      <div class="pp-container">
        <h2 class="pp-h2 pp-center">Co znajdziecie w pakiecie</h2>
        <p class="pp-sub pp-center">
          Kompletny, spójny system dokumentów – od podpisania umowy, przez odbiory kolejnych etapów, aż po dochodzenie
          roszczeń, gdyby przyszło co do czego.
        </p>

        <div class="pp-grid-2 pp-features">
          <div class="pp-feature">
            <div class="pp-feature-icon"><i class="fa fa-file-signature" aria-hidden="true"></i></div>
            <div>
              <h3>Dwie umowy – na dużą i małą skalę</h3>
              <p>
                <strong>Rozbudowana umowa o roboty budowlane</strong> (17 paragrafów) – na budowę domu z generalnym wykonawcą:
                od przekazania terenu budowy, przez materiały i terminy, po rękojmię i odstąpienie. <strong
                  >Prosta umowa o prace budowlane</strong
                > (8 paragrafów) – bo prac za kilka czy kilkadziesiąt tysięcy złotych też nie warto zlecać „na gębę”.
              </p>
            </div>
          </div>

          <div class="pp-feature">
            <div class="pp-feature-icon"><i class="fa fa-clipboard-check" aria-hidden="true"></i></div>
            <div>
              <h3>Siedem protokołów – na każdy moment budowy</h3>
              <p>
                Odbiór prac z miejscem na wady, prace zanikające (zanim znikną pod tynkiem), protokół końcowy,
                inwentaryzacja prac w toku, przekazanie i oddanie terenu budowy, odbiór stolarki okiennej i drzwiowej.
              </p>
            </div>
          </div>

          <div class="pp-feature">
            <div class="pp-feature-icon"><i class="fa fa-envelope-open-text" aria-hidden="true"></i></div>
            <div>
              <h3>Pisma na trudne momenty</h3>
              <p>
                Wezwanie do rozpoczęcia lub dokończenia prac, odstąpienie od umowy, aneks do podpisania od ręki na
                budowie oraz potwierdzenie zapłaty – z wyjaśnieniem różnicy między zaliczką a zadatkiem wprost na
                wzorze.
              </p>
            </div>
          </div>

          <div class="pp-feature">
            <div class="pp-feature-icon"><i class="fa fa-boxes" aria-hidden="true"></i></div>
            <div>
              <h3>Druki, które robią porządek</h3>
              <p>
                Harmonogram prac, kosztorys, wytyczne i uzgodnienia, zamówienie i rozliczenie materiałów, inwentaryzacja
                frontu robót, klauzula RODO i umowa o zachowaniu poufności. Kontrolujecie, co się dzieje i na co idą
                pieniądze.
              </p>
            </div>
          </div>

          <div class="pp-feature">
            <div class="pp-feature-icon"><i class="fa fa-book-open" aria-hidden="true"></i></div>
            <div>
              <h3>Trzy vademecum – wiecie, co podpisujecie</h3>
              <p>
                Każdy paragraf obu umów i załączników omówiony ludzkim językiem, a obok wskazówka, jak wypełnić dane
                pole. Zero prawniczego żargonu bez wyjaśnienia – czytacie i rozumiecie, na co się umawiacie.
              </p>
            </div>
          </div>

          <div class="pp-feature">
            <div class="pp-feature-icon"><i class="fa fa-graduation-cap" aria-hidden="true"></i></div>
            <div>
              <h3>Poradnik prawny w trzech częściach</h3>
              <p>
                <strong>Zanim podpiszecie</strong> – jak zweryfikować wykonawcę i co daje Wam status konsumenta. <strong
                  >W trakcie budowy</strong
                > – porządek w papierach i rozliczeniach.
                <strong>Gdy coś pójdzie nie tak</strong> – krok po kroku od wezwania, przez etap przedsądowy i sąd, aż po
                egzekucję.
              </p>
            </div>
          </div>
        </div>

        <details class="pp-doclist">
          <summary><i class="fa fa-list" aria-hidden="true"></i> Pełna lista – 26 plików w pakiecie</summary>
          <div class="pp-doclist-cols">
            <div>
              <h4>Umowy (2)</h4>
              <ul>
                <li>Umowa o roboty budowlane (rozbudowana, 17 paragrafów)</li>
                <li>Umowa o prace budowlane (prosta, 8 paragrafów)</li>
              </ul>
              <h4>Protokoły (7)</h4>
              <ul>
                <li>Protokół odbioru prac (z miejscem na wady)</li>
                <li>Protokół odbioru prac zanikających</li>
                <li>Protokół końcowy</li>
                <li>Protokół inwentaryzacji prac w toku</li>
                <li>Protokół przekazania terenu budowy</li>
                <li>Protokół oddania terenu budowy</li>
                <li>Protokół odbioru stolarki okiennej i drzwiowej</li>
              </ul>
            </div>
            <div>
              <h4>Pisma i druki (13)</h4>
              <ul>
                <li>Wezwanie do rozpoczęcia / dokończenia prac</li>
                <li>Oświadczenie o odstąpieniu od umowy</li>
                <li>Potwierdzenie zapłaty (zaliczka / zadatek)</li>
                <li>Aneks do umowy</li>
                <li>Harmonogram prac</li>
                <li>Kosztorys</li>
                <li>Wytyczne i uzgodnienia</li>
                <li>Druk zamówienia materiałów</li>
                <li>Potwierdzenie odbioru zamówienia</li>
                <li>Druk rozliczenia materiałów</li>
                <li>Inwentaryzacja frontu robót</li>
                <li>Klauzula informacyjna RODO</li>
                <li>Umowa o zachowaniu poufności</li>
              </ul>
              <h4>Materiały edukacyjne (4)</h4>
              <ul>
                <li>Vademecum umowy rozbudowanej</li>
                <li>Vademecum umowy prostej</li>
                <li>Vademecum załączników</li>
                <li>Poradnik prawny (3 części)</li>
              </ul>
            </div>
          </div>
        </details>
      </div>
    </section>

    <!-- ===== DLACZEGO INNE NIŻ WZORY Z INTERNETU ===== -->
    <section class="pp-section pp-section-cream">
      <div class="pp-container pp-narrow">
        <h2 class="pp-h2 pp-center">
          Najlepsza umowa świata jest bezwartościowa,<br class="pp-br-desktop" /> jeśli wykonawca jej nie podpisze
        </h2>
        <p class="pp-body">
          Znam to z obu stron, bo sam buduję domy. Gdy inwestor wyciąga dwudziestostronicową umowę pełną kar umownych i
          prawniczego żargonu, większość ekip po prostu ją odkłada: „panie, ja tak nie pracuję”. Efekt jest odwrotny od
          zamierzonego – zamiast najlepszej umowy nie ma żadnej.
        </p>
        <p class="pp-body">
          Dlatego te dokumenty powstawały w cztery ręce. <strong>Kancelaria</strong> pilnowała, żeby chroniły Wasze interesy
          i były poprawne prawnie. <strong>Ja</strong> pilnowałem, żeby były realne: napisane zrozumiale, uczciwe dla obu
          stron i możliwe do podpisania bez wielotygodniowych negocjacji.
        </p>

        <ul class="pp-checks">
          <li>
            <i class="fa fa-check" aria-hidden="true"></i>
            <span
              ><strong>Spójny system, nie zbiór przypadkowych plików</strong> – umowy, załączniki i protokoły odwołują się
              do siebie nawzajem i razem tworzą komplet dowodów.</span
            >
          </li>
          <li>
            <i class="fa fa-check" aria-hidden="true"></i>
            <span
              ><strong>Do każdego dokumentu omówienie</strong> – nie dostajecie „gołych” wzorów; vademecum tłumaczy paragraf
              po paragrafie, co podpisujecie i jak to wypełnić.</span
            >
          </li>
          <li>
            <i class="fa fa-check" aria-hidden="true"></i>
            <span
              ><strong>Procedury na wypadek sporu</strong> – poradnik prowadzi krok po kroku, co robić, gdy wykonawca nie
              chce podpisać protokołu, nie usuwa wad albo urywa kontakt.</span
            >
          </li>
        </ul>
      </div>
    </section>

    <!-- ===== DLA KOGO / SCENARIUSZE ===== -->
    <section class="pp-section">
      <div class="pp-container">
        <h2 class="pp-h2 pp-center">W jakiej sytuacji pakiet Wam pomoże</h2>
        <div class="pp-grid-3">
          <div class="pp-scenario">
            <div class="pp-scenario-nr">1</div>
            <h3>Budujecie dom z wykonawcą</h3>
            <p>Największa inwestycja w życiu zasługuje na porządne fundamenty prawne – od pierwszego dnia.</p>
            <ul>
              <li>Rozbudowana umowa o roboty budowlane</li>
              <li>Harmonogram, kosztorys, wytyczne</li>
              <li>Protokoły na każdy etap odbioru</li>
              <li>Vademecum – rozumiecie każdy zapis</li>
            </ul>
          </div>
          <div class="pp-scenario">
            <div class="pp-scenario-nr">2</div>
            <h3>Zlecacie mniejsze prace</h3>
            <p>Płytki, elewacja, instalacje – nawet przy pracach za kilka tysięcy warto mieć papier.</p>
            <ul>
              <li>Prosta umowa o prace budowlane</li>
              <li>Potwierdzenie zapłaty przy zaliczce</li>
              <li>Protokół odbioru na koniec</li>
              <li>Vademecum do prostej umowy</li>
            </ul>
          </div>
          <div class="pp-scenario">
            <div class="pp-scenario-nr">3</div>
            <h3>Problem już się zaczął</h3>
            <p>Opóźnienia, wady, urwany kontakt. Czas działać formalnie – i mieć na wszystko dokument.</p>
            <ul>
              <li>Wezwanie do wykonania prac</li>
              <li>Oświadczenie o odstąpieniu od umowy</li>
              <li>Inwentaryzacja prac w toku</li>
              <li>Poradnik: dochodzenie roszczeń krok po kroku</li>
            </ul>
          </div>
        </div>
        <p class="pp-note pp-center">
          Budowa już trwa, a umowy od początku nie było? Protokoły, pokwitowania i aneksy możecie wprowadzić od dziś –
          każdy podpisany dokument działa na Waszą korzyść.
        </p>
      </div>
    </section>

    <!-- ===== KTO ZA TYM STOI ===== -->
    <section class="pp-section pp-section-cream">
      <div class="pp-container">
        <h2 class="pp-h2 pp-center">Kto za tym stoi</h2>
        <div class="pp-grid-2 pp-authors">
          <div class="pp-author">
            <div class="pp-author-photo">
              <Image
                src={wojtekPortret}
                alt="Wojciech Tracichleb – praktyk budowlany, autor książki Od marzenia do wprowadzenia"
                width={220}
                height={220}
                widths={[160, 220, 320]}
                sizes="(max-width: 640px) 160px, 220px"
                class="pp-author-img"
                loading="lazy"
              />
            </div>
            <h3>Wojciech Tracichleb</h3>
            <p class="pp-author-role">Pozytywnie Zbudowani</p>
            <p>
              Od 2013 roku buduję domy jednorodzinne jako generalny wykonawca i wiem, które dokumenty wykonawcy
              podpisują, a które lądują w szufladzie. Pilnowałem, żeby ten pakiet działał na prawdziwej budowie, nie
              tylko na papierze. Napisałem też książkę „Od marzenia do wprowadzenia” – 608 stron o całym procesie budowy
              domu.
            </p>
          </div>
          <div class="pp-author">
            <div class="pp-author-photo pp-author-photo-icon">
              <i class="fa fa-balance-scale" aria-hidden="true"></i>
            </div>
            <h3>Kancelaria Pewnie</h3>
            <p class="pp-author-role">adw. Rafał Horończyk, Wrocław</p>
            <p>
              Za stronę prawną pakietu odpowiada wrocławska
              <a href="https://kancelariapewnie.pl" target="_blank" rel="noopener noreferrer">Kancelaria Pewnie</a>
              (adw. Rafał Horończyk) – kancelaria wyspecjalizowana w obsłudze przedsiębiorców. Wzory wszystkich dokumentów
              oraz materiały merytoryczne opracowała bezpośrednio
              <strong>mec. Małgorzata Maria Muzyka</strong>, radca prawny, z bogatym doświadczeniem w sprawach z zakresu
              prawa budowlanego. To nie są szablony zebrane z internetu – to dokumentacja przygotowana od zera, pod
              realia budowy domu jednorodzinnego w Polsce.
