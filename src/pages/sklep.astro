---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Sklep',
  description: 'Produkty, które ułatwią Wam budowę własnego domu. Książka, pakiet prawny i więcej.',
};
---

<Layout metadata={metadata}>
  <Hero tagline="Sklep">
    <Fragment slot="title">
      Produkty, które ułatwią Wam <span class="text-accent dark:text-white">budowę domu</span>
    </Fragment>

    <Fragment slot="subtitle">
      Sprawdzone materiały stworzone na podstawie 12 lat doświadczenia w budownictwie jednorodzinnym.
    </Fragment>
  </Hero>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Książka -->
      <div
        class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden border border-gray-100 dark:border-gray-700"
      >
        <div class="p-8">
          <span class="text-sm font-semibold text-accent uppercase tracking-wider">Bestseller</span>
          <h2 class="text-2xl font-bold dark:text-white mt-2 mb-4">Od Marzenia Do Wprowadzenia</h2>
          <p class="text-muted mb-6">
            600 stron praktycznej wiedzy o budowie domu jednorodzinnego. Kompletny przewodnik od wyboru działki po
            klucz w drzwiach.
          </p>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-3xl font-bold dark:text-white">119 zł</span>
          </div>
          <a
            href="https://pozytywnie-zbudowani.salescrm.pl/cart/add_product/15603"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-secondary transition-colors"
          >
            Kup książkę
          </a>
        </div>
      </div>

      <!-- Pakiet prawny -->
      <div
        class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden border border-gray-100 dark:border-gray-700 relative"
      >
        <div class="absolute top-4 right-4 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase">
          Wkrótce
        </div>
        <div class="p-8">
          <span class="text-sm font-semibold text-primary uppercase tracking-wider">Nowy produkt</span>
          <h2 class="text-2xl font-bold dark:text-white mt-2 mb-4">Pakiet Prawny</h2>
          <p class="font-medium dark:text-white mb-2">Twój niezbędnik prawny przy budowie domu</p>
          <p class="text-muted mb-6">
            Praktyczne szkolenie oraz komplet gotowych wzorów dokumentów, opracowany we współpracy z profesjonalną
            kancelarią prawną. Zawiera m.in. wzory umów, protokołów odbioru, wezwań do zapłaty i innych pism, które
            pomogą Ci bezpiecznie zatrudnić wykonawcę i egzekwować swoje prawa jako inwestor. Wszystkie kwestie prawne
            między Tobą a wykonawcą wyjaśnione jasno i konkretnie — krok po kroku.
          </p>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-lg font-semibold text-accent dark:text-white">PREMIERA 2026</span>
          </div>
          <span
            class="inline-flex items-center gap-2 px-6 py-3 bg-gray-300 dark:bg-gray-600 text-gray-500 dark:text-gray-400 font-semibold rounded-lg cursor-not-allowed"
          >
            Już wkrótce
          </span>
        </div>
      </div>
    </div>
  </div>
</Layout>
