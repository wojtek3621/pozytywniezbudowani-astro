---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Sklep',
  description: 'Produkty, które ułatwią Wam budowę własnego domu. Książka, pakiet prawny i więcej.',
};
---

<Layout metadata={metadata}>
  <Hero tagline="Sklep">
    <Fragment slot="title">
      Produkty, które ułatwią Wam <span class="text-accent dark:text-white">budowę domu</span>
    </Fragment>

    <Fragment slot="subtitle">
      Sprawdzone materiały stworzone na podstawie 12 lat doświadczenia w budownictwie jednorodzinnym.
    </Fragment>
  </Hero>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Książka -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden border border-gray-100 dark:border-gray-700">
        <div class="p-8">
          <span class="text-sm font-semibold text-accent uppercase tracking-wider">Bestseller</span>
          <h2 class="text-2xl font-bold dark:text-white mt-2 mb-4">Od Marzenia Do Wprowadzenia</h2>
          <p class="text-muted mb-6">
            Ponad 600 stron praktycznej wiedzy o budowie domu jednorodzinnego. Kompletny przewodnik
            od wyboru działki po klucz w drzwiach.
          </p>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-3xl font-bold dark:text-white">119 zł</span>
          </div>
          <a href="https://pozytywnie-zbudowani.salescrm.pl/cart/add_product/15603"
            target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-secondary transition-colors">
            Kup książkę
          </a>
        </div>
      </div>

      <!-- Pakiet prawny -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg overflow-hidden border border-gray-100 dark:border-gray-700">
        <div class="p-8">
          <span class="text-sm font-semibold text-primary uppercase tracking-wider">Nowy produkt</span>
          <h2 class="text-2xl font-bold dark:text-white mt-2 mb-4">Pakiet Prawny</h2>
          <p class="text-muted mb-6">
            Komplet dokumentów prawnych potrzebnych przy budowie domu. Umowy z wykonawcami,
            protokoły odbiorów, checklisty — gotowe do użycia.
          </p>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-3xl font-bold dark:text-white">4,99 zł</span>
          </div>
          <a href="https://pozytywnie-zbudowani.salescrm.pl/cart/add_product/15603"
            target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-secondary transition-colors">
            Kup pakiet
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
