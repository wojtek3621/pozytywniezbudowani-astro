---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Stats from '~/components/widgets/Stats.astro';

import heroImg from '~/assets/images/site/hero-bg.jpg';
import ksiazkaImg from '~/assets/images/site/ksiazka-hero.jpg';
import wojtekImg from '~/assets/images/site/wojtek-portrait.jpg';

const metadata = {
  title: 'Budowa domu jednorodzinnego krok po kroku — Wojciech Tracichleb',
  ignoreTitleTemplate: true,
  description: 'Budowa domu jednorodzinnego krok po kroku. Praktyczny poradnik od Wojciecha Tracichleb — autora ksiazki Od Marzenia Do Wprowadzenia.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Czytaj blog',
        href: '/blog/',
        icon: 'tabler:book',
      },
      {
        text: 'Poznaj ksiazke',
        href: '/ksiazka/',
        icon: 'tabler:arrow-right',
      },
    ]}
    image={{ src: heroImg, alt: 'Budowa domu jednorodzinnego — Pozytywnie Zbudowani' }}
  >
    <Fragment slot="title">
      Budujecie dom?<br />
      <span class="text-accent dark:text-white">Jestescie we wlasciwym miejscu.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Wiem, jak duzym wyzwaniem potrafi byc budowa wlasnego domu. Dziesiatki decyzji do podjecia,
      kilkanascie roznych ekip i natlok informacji z kazdej mozliwej strony. Dlatego tu jestem —
      zeby Was przez to przeprowadzic.
    </Fragment>
  </Hero>

  <!-- Ksiazka -->
  <Content
    isReversed
    id="ksiazka"
    tagline="Ksiazka"
    title="Od Marzenia Do Wprowadzenia"
    items={[
      {
        title: 'Ponad 600 stron praktycznej wiedzy',
        description: 'Kompletny przewodnik po budowie domu — od wyboru dzialki, przez projekt, formalnosci, az po klucz w drzwiach.',
      },
      {
        title: 'Napisana przez praktyka',
        description: 'Nie teoria z podrecznikow, a doswiadczenie zebrane podczas budowy setek domow od 2013 roku.',
      },
      {
        title: 'Dla kazdego inwestora',
        description: 'Niezaleznie czy dopiero marzycie o domu, czy jestescie w trakcie budowy — ta ksiazka zmieni Wasze podejscie.',
      },
    ]}
    image={{
      src: ksiazkaImg,
      alt: 'Ksiazka Od Marzenia Do Wprowadzenia — Wojciech Tracichleb',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Budowa domu jednorodzinnego — kompletny poradnik
      </h3>
      Przeprowadze Was przez caly proces budowy domu w sposob prosty i praktyczny.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- O mnie -->
  <Content
    isAfterContent
    id="o-mnie"
    items={[
      {
        title: 'Od 2013 roku w budownictwie jednorodzinnym',
        description: 'Generalny wykonawca, ktory zna proces budowy z kazdej perspektywy — od strony inwestora, wykonawcy, architekta i inspektora.',
      },
      {
        title: 'Setki zrealizowanych projektow',
        description: 'Towarzyszylem setkom osob w powstawaniu ich wymarzonego domu. Sam rowniez jako inwestor wybudowalem wlasny dom.',
      },
      {
        title: 'Autor i edukator',
        description: 'Napisalem ksiazke, prowadze bloga i dziele sie wiedza, ktora chcialbym miec sam, gdy zaczynalem przygode z budownictwem.',
      },
    ]}
    image={{
      src: wojtekImg,
      alt: 'Wojciech Tracichleb — autor Pozytywnie Zbudowani',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Wojciech Tracichleb
      </h3>
      Przedsiebiorca budowlany z pasja do przekazywania wiedzy.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Stats -->
  <Stats
    stats={[
      { title: 'Lat doswiadczenia', amount: '12+' },
      { title: 'Artykulow na blogu', amount: '119' },
      { title: 'Stron w ksiazce', amount: '600+' },
      { title: 'Zbudowanych domow', amount: '100+' },
    ]}
  />

  <!-- Najnowsze na blogu -->
  <BlogLatestPosts
    title="Najnowsze na blogu"
    information="Praktyczne porady dotyczace budowy domu jednorodzinnego — od wyboru dzialki, przez projekt i formalnosci, az po wykonczeniowke."
  />

  <!-- CTA Newsletter -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Przejdz do bloga',
        href: '/blog/',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">
      Budujecie dom?<br class="block sm:hidden" />
      <span class="sm:whitespace-nowrap">Zacznijcie od wiedzy.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Ponad 119 artykulow o budowie domu jednorodzinnego. Praktyczne porady oparte na 12 latach doswiadczenia.
    </Fragment>
  </CallToAction>
</Layout>
