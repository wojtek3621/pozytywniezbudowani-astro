---
import Layout from '~/layouts/PageLayout.astro';
import OrganizationSchema from '~/components/common/OrganizationSchema.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Stats from '~/components/widgets/Stats.astro';

import heroImg from '~/assets/images/site/hero-bg.jpg';
import ksiazkaImg from '~/assets/images/site/ksiazka-hero.jpg';
import wojtekImg from '~/assets/images/site/wojtek-portrait.jpg';

const metadata = {
  title: 'Budowa domu jednorodzinnego krok po kroku — Wojciech Tracichleb',
  ignoreTitleTemplate: true,
  description:
    'Budowa domu jednorodzinnego krok po kroku | Od Marzenia Do Wprowadzenia Wojciech Tracichleb | Kompleksowy poradnik budowy domu',
};
---

<Layout metadata={metadata}>
  <OrganizationSchema />

  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Czytaj blog',
        href: '/blog/',
        icon: 'tabler:book',
      },
      {
        text: 'Poznaj książkę',
        href: '/ksiazka/',
        icon: 'tabler:arrow-right',
      },
    ]}
    image={{ src: heroImg, alt: 'Budowa domu jednorodzinnego — Pozytywnie Zbudowani' }}
  >
    <Fragment slot="title">
      Budujecie dom?<br />
      <span class="text-accent dark:text-white">Jesteście we właściwym miejscu.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Wiem, jak dużym wyzwaniem potrafi być budowa własnego domu. Dziesiątki decyzji do podjęcia, kilkanaście różnych
      ekip i natłok informacji z każdej możliwej strony. Dlatego tu jestem — żeby Was przez to przeprowadzić.
    </Fragment>
  </Hero>

  <!-- Cel -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 text-center">
    <p class="text-lg text-muted leading-relaxed">
      Od 12 lat zajmuję się budownictwem jednorodzinnym i postawiłem sobie za cel uporządkowanie w jedną spójną całość
      wiedzy, która jest Wam potrzebna, aby sprawnie przejść przez cały ten proces.
    </p>
  </div>

  <!-- Książka -->
  <Content
    isReversed
    id="ksiazka"
    tagline="Książka"
    title="Od Marzenia Do Wprowadzenia"
    items={[
      {
        title: 'Ponad 600 stron praktycznej wiedzy',
        description:
          'Kompletny przewodnik po budowie domu — od wyboru działki, przez projekt, formalności, aż po klucz w drzwiach.',
      },
      {
        title: 'Napisana przez praktyka',
        description: 'Nie teoria z podręczników, a doświadczenie zebrane podczas budowy setek domów od 2013 roku.',
      },
      {
        title: 'Dla każdego inwestora',
        description:
          'Niezależnie czy dopiero marzycie o domu, czy jesteście w trakcie budowy — ta książka zmieni Wasze podejście.',
      },
    ]}
    image={{
      src: ksiazkaImg,
      alt: 'Książka Od Marzenia Do Wprowadzenia — Wojciech Tracichleb',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Od Marzenia Do Wprowadzenia
      </h3>
      Marzysz o własnym domu, ale nie wiesz, od czego zacząć? Jesteś w trakcie budowy i potrzebujesz sprawdzonych
      rozwiązań? A może właśnie wybrałeś projekt i szukasz praktycznych wskazówek?
      <br /><br />
      Ta książka przeprowadzi Cię przez kompletny proces budowy własnego domu — od koncepcji i planowania, przez
      wszystkie etapy budowy, aż po malowanie i kładzenie płytek. Oto Twój przewodnik w drodze do własnego domu.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- O mnie -->
  <Content
    isAfterContent
    id="o-mnie"
    items={[
      {
        title: 'Od 2013 roku w budownictwie jednorodzinnym',
        description:
          'Specjalizuje się wyłącznie w domach jednorodzinnych, uczestnicząc w powstawaniu kilkuset takich budynków. Jako właściciel firmy budowlanej zajmującej się generalnym wykonawstwem zna proces budowy z każdej perspektywy.',
      },
      {
        title: 'Setki zrealizowanych projektów',
        description:
          'Towarzyszył setkom osób w powstawaniu ich wymarzonego domu. Sam również jako inwestor wybudował własny dom jednorodzinny. Razem z żoną prowadził również biuro architektury wnętrz, obsługując klientów z Polski i zagranicy.',
      },
      {
        title: 'Autor i edukator',
        description:
          'Pisząc książkę „Od marzenia do wprowadzenia", postawił sobie za cel przekazanie praktycznej wiedzy w sposób zrozumiały dla każdego przyszłego właściciela domu — pisząc prosto, konkretnie i na temat.',
      },
    ]}
    image={{
      src: wojtekImg,
      alt: 'Wojciech Tracichleb — autor Pozytywnie Zbudowani',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Wojciech Tracichleb</h3>
      Przedsiębiorca budowlany z pasją do przekazywania wiedzy. Od 2013 roku zawodowo zajmuje się tematyką budownictwa
      jednorodzinnego. Na co dzień prowadzi firmę budowlaną i jako generalny wykonawca buduje domy dla swoich klientów.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Stats -->
  <Stats
    stats={[
      { title: 'Lat doświadczenia', amount: '12+' },
      { title: 'Artykułów na blogu', amount: '119' },
      { title: 'Stron w książce', amount: '600+' },
      { title: 'Zbudowanych domów', amount: '100+' },
    ]}
  />

  <!-- Newsletter CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Dołącz do newslettera',
        href: 'https://pozytywniezbudowani.pl/newsletter/',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title"> Dołącz do newslettera </Fragment>

    <Fragment slot="subtitle">
      Regularnie dzielę się praktyczną wiedzą o budowie domu. Zapisz się, aby nie przegapić najważniejszych wskazówek.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </CallToAction>

  <!-- Najnowsze na blogu -->
  <BlogLatestPosts
    title="Najnowsze na blogu"
    information="Praktyczne porady dotyczące budowy domu jednorodzinnego — od wyboru działki, przez projekt i formalności, aż po wykończeniówkę."
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Przejdź do bloga',
        href: '/blog/',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">
      Budujecie dom?<br class="block sm:hidden" />
      <span class="sm:whitespace-nowrap">Zacznijcie od wiedzy.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Ponad 119 artykułów o budowie domu jednorodzinnego. Praktyczne porady oparte na 12 latach doświadczenia.
    </Fragment>
  </CallToAction>
</Layout>
