---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Stats from '~/components/widgets/Stats.astro';

import heroImg from '~/assets/images/site/hero-bg.jpg';
import ksiazkaImg from '~/assets/images/site/ksiazka-hero.jpg';
import wojtekImg from '~/assets/images/site/wojtek-portrait.jpg';

const metadata = {
  title: 'Budowa domu jednorodzinnego krok po kroku — Wojciech Tracichleb',
  ignoreTitleTemplate: true,
  description: 'Budowa domu jednorodzinnego krok po kroku | Od Marzenia Do Wprowadzenia Wojciech Tracichleb | Kompleksowy poradnik budowy domu',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Czytaj blog',
        href: '/blog/',
        icon: 'tabler:book',
      },
      {
        text: 'Poznaj książkę',
        href: '/ksiazka/',
        icon: 'tabler:arrow-right',
      },
    ]}
    image={{ src: heroImg, alt: 'Budowa domu jednorodzinnego — Pozytywnie Zbudowani' }}
  >
    <Fragment slot="title">
      Budujecie dom?<br />
      <span class="text-accent dark:text-white">Jesteście we właściwym miejscu.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Wiem, jak dużym wyzwaniem potrafi być budowa własnego domu. Dziesiątki decyzji do podjęcia,
      kilkanaście różnych ekip i natłok informacji z każdej możliwej strony. Dlatego tu jestem —
      żeby Was przez to przeprowadzić.
    </Fragment>
  </Hero>

  <!-- Książka -->
  <Content
    isReversed
    id="ksiazka"
    tagline="Książka"
    title="Od Marzenia Do Wprowadzenia"
    items={[
      {
        title: 'Ponad 600 stron praktycznej wiedzy',
        description: 'Kompletny przewodnik po budowie domu — od wyboru działki, przez projekt, formalności, aż po klucz w drzwiach.',
      },
      {
        title: 'Napisana przez praktyka',
        description: 'Nie teoria z podręczników, a doświadczenie zebrane podczas budowy setek domów od 2013 roku.',
      },
      {
        title: 'Dla każdego inwestora',
        description: 'Niezależnie czy dopiero marzycie o domu, czy jesteście w trakcie budowy — ta książka zmieni Wasze podejście.',
      },
    ]}
    image={{
      src: ksiazkaImg,
      alt: 'Książka Od Marzenia Do Wprowadzenia — Wojciech Tracichleb',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Budowa domu jednorodzinnego — kompletny poradnik
      </h3>
      Przeprowadzę Was przez cały proces budowy domu w sposób prosty i praktyczny.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- O mnie -->
  <Content
    isAfterContent
    id="o-mnie"
    items={[
      {
        title: 'Od 2013 roku w budownictwie jednorodzinnym',
        description: 'Generalny wykonawca, który zna proces budowy z każdej perspektywy — od strony inwestora, wykonawcy, architekta i inspektora.',
      },
      {
        title: 'Setki zrealizowanych projektów',
        description: 'Towarzyszyłem setkom osób w powstawaniu ich wymarzonego domu. Sam również jako inwestor wybudowałem własny dom.',
      },
      {
        title: 'Autor i edukator',
        description: 'Napisałem książkę, prowadzę bloga i dzielę się wiedzą, którą chciałbym mieć sam, gdy zaczynałem przygodę z budownictwem.',
      },
    ]}
    image={{
      src: wojtekImg,
      alt: 'Wojciech Tracichleb — autor Pozytywnie Zbudowani',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Wojciech Tracichleb
      </h3>
      Przedsiębiorca budowlany z pasją do przekazywania wiedzy.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Stats -->
  <Stats
    stats={[
      { title: 'Lat doświadczenia', amount: '12+' },
      { title: 'Artykułów na blogu', amount: '119' },
      { title: 'Stron w książce', amount: '600+' },
      { title: 'Zbudowanych domów', amount: '100+' },
    ]}
  />

  <!-- Najnowsze na blogu -->
  <BlogLatestPosts
    title="Najnowsze na blogu"
    information="Praktyczne porady dotyczące budowy domu jednorodzinnego — od wyboru działki, przez projekt i formalności, aż po wykończeniówkę."
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Przejdź do bloga',
        href: '/blog/',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">
      Budujecie dom?<br class="block sm:hidden" />
      <span class="sm:whitespace-nowrap">Zacznijcie od wiedzy.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Ponad 119 artykułów o budowie domu jednorodzinnego. Praktyczne porady oparte na 12 latach doświadczenia.
    </Fragment>
  </CallToAction>
</Layout>
