---
import Layout from '~/layouts/PageLayout.astro';
import OrganizationSchema from '~/components/common/OrganizationSchema.astro';
import Image from '~/components/common/Image.astro';

import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Stats from '~/components/widgets/Stats.astro';

import heroImg from '~/assets/images/site/hero-wojtek-ksiazka-portrait.jpg';
import ksiazkaImg from '~/assets/images/site/ksiazka-hero.jpg';
import wojtekImg from '~/assets/images/site/wojtek-o-mnie.jpg';

const metadata = {
  title: 'Budowa domu od marzenia do wprowadzenia – Centrum Dowodzenia Budową | Wojciech Tracichleb',
  ignoreTitleTemplate: true,
  description:
    'Pomogę Wam przejść przez całą budowę domu – od marzenia do wprowadzenia. Praktyk od 2013 roku: książka, darmowe Centrum Dowodzenia Budową, 119 poradników.',
};
---

<Layout metadata={metadata}>
  <OrganizationSchema />

  <!-- Split Hero -->
  <section class="relative md:-mt-[76px] not-prose">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="pt-0 md:pt-[76px]"></div>
      <div class="py-12 md:py-20">
        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
          <!-- LEFT: Copy -->
          <div class="order-2 md:order-1">
            <p class="text-sm text-muted uppercase tracking-wider mb-4">Wojciech Tracichleb</p>

            <h1
              class="text-4xl md:text-5xl font-display font-bold leading-tight tracking-tight mb-6 dark:text-gray-200"
            >
              Marzycie o budowie domu albo już ją planujecie?<br />Dobrze trafiliście.
            </h1>

            <p class="text-xl text-muted dark:text-slate-400 mb-8 leading-relaxed">
              Jestem praktykiem – od 2013 roku buduję domy jako generalny wykonawca. Pomogę Wam przejść
              przez cały proces: od marzenia do wprowadzenia.
            </p>

            <!-- CTA row -->
            <!-- LPO 2026-07-18: moduł BBN cofnięty do przeglądu (rejestracja
                 zamknięta) – przycisk ZAPRASZA do poznania Centrum, nie do
                 założenia konta (to prowadziłoby na „rejestracja wkrótce").
                 Re-otwarcie = przywrócić tekst „Załóżcie darmowe Centrum
                 Dowodzenia Budową". -->
            <div class="flex flex-col sm:flex-row gap-4 mb-6">
              <a
                href="/centrum"
                class="inline-flex items-center justify-center bg-[#c5a44e] hover:bg-[#b08f3a] text-white font-bold py-4 px-8 rounded-lg shadow-lg transition duration-200 text-center"
              >
                Poznajcie Centrum Dowodzenia Budową
              </a>
              <a
                href="/ksiazka"
                class="inline-flex items-center justify-center border-2 border-[#3369B1] text-[#3369B1] hover:bg-[#3369B1] hover:text-white font-semibold py-4 px-8 rounded-lg transition duration-200 text-center"
              >
                Poznajcie książkę
              </a>
            </div>

            <!-- Testimonial -->
            <p class="text-sm text-muted italic mt-6">
              &laquo;Ta książka powinna być dołączana do każdego pozwolenia na budowę.&raquo;
              <br />
              <span class="not-italic font-medium">– Daria Bućko, Extradom.pl</span>
            </p>

            <!-- Stats row -->
            <div class="flex flex-wrap gap-8 mt-8 pt-6 border-t border-gray-200 dark:border-slate-700">
              <div>
                <span class="text-2xl font-bold dark:text-white">12+</span>
                <span class="block text-sm text-muted">Lat doświadczenia</span>
              </div>
              <div>
                <span class="text-2xl font-bold dark:text-white">119</span>
                <span class="block text-sm text-muted">Artykułów</span>
              </div>
              <div>
                <span class="text-2xl font-bold dark:text-white">600</span>
                <span class="block text-sm text-muted">Stron w książce</span>
              </div>
            </div>
          </div>

          <!-- RIGHT: Image -->
          <div class="order-1 md:order-2 relative">
            <div class="relative overflow-hidden rounded-lg shadow-xl">
              <Image
                src={heroImg}
                alt="Wojciech Tracichleb – budowa domu bez chaosu"
                class="w-full h-auto md:h-[600px] object-cover rounded-lg"
                widths={[400, 768, 1200]}
                width={1200}
                sizes="(max-width: 768px) 100vw, 50vw"
                aspectRatio="2:3"
                layout="cover"
                loading="eager"
                decoding="async"
              />
              <!-- Gradient overlay left (desktop) -->
              <div
                class="hidden md:block absolute inset-0 bg-gradient-to-r from-white/30 via-transparent to-transparent dark:from-gray-900/30 pointer-events-none"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- S2 · Gdzie jesteście? (LPO – 04-koncepcja-strony.md §3; jedna rama
       poznawcza z ekosystemem). Telemetria kliknięć kafli: dataLayer event
       s2_faza_klik (GTM-PKRLVW2G) – pierwszy rozkład faz publiczności (§4). -->
  <section class="py-12 md:py-16 bg-slate-50 dark:bg-slate-800" id="gdzie-jestescie">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold dark:text-white mb-3 font-display text-center">
        Gdzie jesteście?
      </h2>
      <p class="text-muted text-lg text-center max-w-3xl mx-auto mb-10">
        Każda faza budowy potrzebuje czego innego. Wybierzcie swoją – pokażę Wam najlepsze wejście.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white dark:bg-slate-900 rounded-lg p-6 shadow-sm flex flex-col">
          <h3 class="text-lg font-bold dark:text-white mb-2 font-display">Marzymy, rozglądamy się</h3>
          <p class="text-muted text-sm mb-4 flex-1">
            Dom jest jeszcze pomysłem – sprawdzacie, z czym to się je.
          </p>
          <div class="flex flex-col gap-2 text-sm">
            <a href="/darmowy-rozdzial" class="s2-link font-semibold text-secondary hover:underline" data-faza="marzymy"
              >Darmowy rozdział książki →</a
            >
            <a href="/mapa-12-tygodni/" class="s2-link font-semibold text-secondary hover:underline" data-faza="marzymy"
              >Mapa 12 tygodni do startu →</a
            >
            <a href="/blog/" class="s2-link font-semibold text-secondary hover:underline" data-faza="marzymy"
              >Blog – 462 poradniki →</a
            >
          </div>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-lg p-6 shadow-sm flex flex-col border-2 border-primary/40">
          <h3 class="text-lg font-bold dark:text-white mb-2 font-display">Planujemy budowę</h3>
          <p class="text-muted text-sm mb-4 flex-1">
            Działka jest albo prawie jest – zaczyna się liczyć kolejność kroków.
          </p>
          <div class="flex flex-col gap-2 text-sm">
            <a href="/mapa-12-tygodni/" class="s2-link font-semibold text-secondary hover:underline" data-faza="planujemy"
              >Mapa 12 tygodni do startu →</a
            >
            <a href="/ksiazka" class="s2-link font-semibold text-secondary hover:underline" data-faza="planujemy"
              >Książka „Od marzenia do wprowadzenia" →</a
            >
          </div>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-lg p-6 shadow-sm flex flex-col">
          <h3 class="text-lg font-bold dark:text-white mb-2 font-display">Budujemy</h3>
          <p class="text-muted text-sm mb-4 flex-1">
            Dom rośnie – teraz budżet i papiery decydują, jak to się skończy.
          </p>
          <div class="flex flex-col gap-2 text-sm">
            <a href="/centrum" class="s2-link font-semibold text-secondary hover:underline" data-faza="budujemy"
              >Centrum Dowodzenia Budową →</a
            >
            <a href="/pakiet-prawny" class="s2-link font-semibold text-secondary hover:underline" data-faza="budujemy"
              >Pakiet Prawny →</a
            >
          </div>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-lg p-6 shadow-sm flex flex-col">
          <h3 class="text-lg font-bold dark:text-white mb-2 font-display">Kończymy, mieszkamy</h3>
          <p class="text-muted text-sm mb-4 flex-1">
            Przed Wami odbiory, formalności końcowe i pierwsze miesiące w domu.
          </p>
          <div class="flex flex-col gap-2 text-sm">
            <a
              href="/blog/odbior-domu-do-uzytkowania-procedura-krok-po-kroku/"
              class="s2-link font-semibold text-secondary hover:underline"
              data-faza="konczymy">Odbiór domu krok po kroku →</a
            >
            <a href="/blog/" class="s2-link font-semibold text-secondary hover:underline" data-faza="konczymy"
              >Blog – wykończenie i odbiory →</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
  <script>
    // S2: telemetria kliknięć kafli faz → dataLayer (GTM). Delegacja – zero
    // zależności; wysyłamy PRZED nawigacją (queue przeżywa unload w GTM).
    const w = window as unknown as { dataLayer?: Record<string, unknown>[] };
    document.querySelectorAll<HTMLAnchorElement>('#gdzie-jestescie .s2-link').forEach((a) => {
      a.addEventListener('click', () => {
        w.dataLayer = w.dataLayer || [];
        w.dataLayer.push({
          event: 's2_faza_klik',
          s2_faza: a.dataset.faza,
          s2_cel: a.getAttribute('href'),
        });
      });
    });
  </script>

  <!-- Cel -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 text-center">
    <p class="text-lg text-muted leading-relaxed">
      Od 13 lat zajmuję się budownictwem jednorodzinnym i postawiłem sobie za cel uporządkowanie w jedną spójną całość
      wiedzy, która jest Wam potrzebna, aby sprawnie przejść przez cały ten proces.
    </p>
  </div>

  <!-- Książka -->
  <Content
    isReversed
    id="ksiazka"
    tagline="Książka"
    title="Od Marzenia Do Wprowadzenia"
    items={[
      {
        title: 'Aż 600 stron napisanych przystępnym językiem',
        description:
          'Kompletny przewodnik po budowie domu – od wyboru działki, przez projekt, formalności, aż po klucz w drzwiach.',
      },
      {
        title: 'Napisana przez praktyka',
        description: 'Nie teoria z podręczników, a doświadczenie zebrane podczas budowy setek domów od 2013 roku.',
      },
      {
        title: 'Dla każdego inwestora',
        description:
          'Niezależnie czy dopiero marzycie o domu, czy jesteście w trakcie budowy – ta książka zmieni Wasze podejście.',
      },
    ]}
    image={{
      src: ksiazkaImg,
      alt: 'Książka Od Marzenia Do Wprowadzenia – Wojciech Tracichleb',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Od Marzenia Do Wprowadzenia</h3>
      Marzysz o własnym domu, ale nie wiesz, od czego zacząć? Jesteś w trakcie budowy i potrzebujesz sprawdzonych rozwiązań?
      A może właśnie wybrałeś projekt i szukasz praktycznych wskazówek?
      <br /><br />
      Ta książka przeprowadzi Cię przez kompletny proces budowy własnego domu – od koncepcji i planowania, przez wszystkie
      etapy budowy, aż po malowanie i kładzenie płytek. Oto Twój przewodnik w drodze do własnego domu.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- O mnie -->
  <Content
    isAfterContent
    id="o-mnie"
    items={[
      {
        title: 'Od 2013 roku w budownictwie jednorodzinnym',
        description:
          'Specjalizuje się wyłącznie w domach jednorodzinnych, uczestnicząc w powstawaniu kilkuset takich budynków. Jako właściciel firmy budowlanej zajmującej się generalnym wykonawstwem zna proces budowy z każdej perspektywy.',
      },
      {
        title: 'Setki zrealizowanych projektów',
        description:
          'Towarzyszył setkom osób w powstawaniu ich wymarzonego domu. Sam również jako inwestor wybudował własny dom jednorodzinny. Razem z żoną prowadził również biuro architektury wnętrz, obsługując klientów z Polski i zagranicy.',
      },
      {
        title: 'Autor i edukator',
        description:
          'Pisząc książkę „Od marzenia do wprowadzenia", postawił sobie za cel przekazanie praktycznej wiedzy w sposób zrozumiały dla każdego przyszłego właściciela domu – pisząc prosto, konkretnie i na temat.',
      },
    ]}
    image={{
      src: wojtekImg,
      alt: 'Wojciech Tracichleb – autor Pozytywnie Zbudowani',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Wojciech Tracichleb</h3>
      Przedsiębiorca budowlany z pasją do przekazywania wiedzy. Od 2013 roku zawodowo zajmuje się tematyką budownictwa jednorodzinnego.
      Na co dzień prowadzi firmę budowlaną i jako generalny wykonawca buduje domy dla swoich klientów.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Stats -->
  <Stats
    stats={[
      { title: 'Lat doświadczenia', amount: '12+' },
      { title: 'Artykułów na blogu', amount: '119' },
      { title: 'Stron w książce', amount: '600' },
      { title: 'Zbudowanych domów', amount: '100+' },
    ]}
  />

  <!-- Najnowsze na blogu – z override na animacje opacity -->
  <div class="blog-cards-visible">
    <BlogLatestPosts
      title="Najnowsze na blogu"
      information="Praktyczne porady dotyczące budowy domu jednorodzinnego – od wyboru działki, przez projekt i formalności, aż po wykończeniówkę."
    />
  </div>

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Przejdź do bloga',
        href: '/blog/',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">
      Budujecie dom?<br class="block sm:hidden" />
      <span class="sm:whitespace-nowrap">Zacznijcie od wiedzy.</span>
    </Fragment>

    <Fragment slot="subtitle">
      Ponad 119 artykułów o budowie domu jednorodzinnego. Praktyczne porady oparte na 13 latach doświadczenia.
    </Fragment>
  </CallToAction>
</Layout>

<style>
  /* Override intersect-based opacity animation on blog cards – show immediately */
  .blog-cards-visible :global(article) {
    opacity: 1 !important;
    animation: none !important;
  }
</style>
