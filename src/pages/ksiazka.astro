---
import Layout from '~/layouts/PageLayout.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Features from '~/components/widgets/Features.astro';
import Image from '~/components/common/Image.astro';
import BookNavigation from '~/components/widgets/BookNavigation.astro';

import bookCoverCta from '~/assets/images/ksiazka/book-cover-cta.jpg';
import heroWojtekKsiazka from '~/assets/images/site/hero-wojtek-ksiazka-portrait.jpg';
import wojtekDlaKogoImg from '~/assets/images/site/wojtek-dla-kogo.jpg';
import wojtekOAutorzieImg from '~/assets/images/site/wojtek-o-autorze-ksiazka.jpg';
import extradomLogo from '~/assets/images/partners/extradom.svg';

import interior01 from '~/assets/images/ksiazka/interior-01.jpg';
import interior02 from '~/assets/images/ksiazka/interior-02.jpg';
import interior03 from '~/assets/images/ksiazka/interior-03.jpg';
import interior04 from '~/assets/images/ksiazka/interior-04.jpg';
import interior05 from '~/assets/images/ksiazka/interior-05.jpg';
import interior06 from '~/assets/images/ksiazka/interior-06.jpg';
import interior07 from '~/assets/images/ksiazka/interior-07.jpg';
import interior08 from '~/assets/images/ksiazka/interior-08.jpg';

const metadata = {
  title: 'Od Marzenia Do Wprowadzenia — Kompletny przewodnik budowy domu | Wojciech Tracichleb',
  description:
    '608 stron, 86 rozdziałów, 13 lat doświadczenia generalnego wykonawcy. Kompletny przewodnik dla inwestora — od pierwszej myśli o budowie do wprowadzenia. 119 zł.',
  robots: { index: true, follow: true },
};

const interiorImages = [
  { src: interior01, alt: 'Rozkładówka książki 1' },
  { src: interior02, alt: 'Rozkładówka książki 2' },
  { src: interior03, alt: 'Rozkładówka książki 3' },
  { src: interior04, alt: 'Rozkładówka książki 4' },
  { src: interior05, alt: 'Rozkładówka książki 5' },
  { src: interior06, alt: 'Rozkładówka książki 6' },
  { src: interior07, alt: 'Rozkładówka książki 7' },
  { src: interior08, alt: 'Rozkładówka książki 8' },
];

const salesUrl = 'https://pozytywnie-zbudowani.salescrm.pl/cart/add_product/15603';
---

<Layout metadata={metadata}>
  <!-- Book schema JSON-LD (minimal, BEZ aggregateRating — Google penalty risk) -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Book',
      name: 'Od Marzenia Do Wprowadzenia',
      author: {
        '@type': 'Person',
        name: 'Wojciech Tracichleb',
      },
      publisher: {
        '@type': 'Organization',
        name: 'Vultima sp. z o.o.',
        url: 'https://pozytywniezbudowani.pl',
      },
      inLanguage: 'pl',
      numberOfPages: 608,
      bookFormat: 'https://schema.org/Hardcover',
      image: 'https://pozytywniezbudowani.pl/images/ksiazka-hero.jpg',
      offers: {
        '@type': 'Offer',
        price: '119.00',
        priceCurrency: 'PLN',
        availability: 'https://schema.org/InStock',
        url: 'https://pozytywnie-zbudowani.salescrm.pl/cart/add_product/15603',
      },
    })}
  />

  <!-- HERO SPLIT — dark bg, portret Wojtka, 4 value props, CTA -->
  <section class="bg-slate-900 py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <!-- LEFT: portret (mobile: order-2) -->
        <div class="relative order-2 md:order-1">
          <Image
            src={heroWojtekKsiazka}
            alt="Wojciech Tracichleb — autor książki Od Marzenia Do Wprowadzenia"
            widths={[400, 768, 1200]}
            width={600}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="eager"
            class="w-full h-auto rounded-lg shadow-2xl"
          />
        </div>

        <!-- RIGHT: copy (mobile: order-1) -->
        <div class="order-1 md:order-2">
          <p class="text-amber-400 text-sm font-bold uppercase tracking-wider mb-4">
            KOMPLETNY PRZEWODNIK DLA INWESTORA
          </p>
          <h1 class="font-display text-4xl md:text-5xl font-bold text-white leading-tight mb-5">
            Zrozum każdą decyzję budowlaną — krok po kroku
          </h1>
          <p class="text-lg text-slate-300 mb-6 leading-relaxed">
            608 stron, 86 rozdziałów, 13 lat doświadczenia generalnego wykonawcy. Kompletny przewodnik dla inwestora —
            od pierwszej myśli o budowie do wprowadzenia.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-amber-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path>
              </svg>
              <span class="text-slate-200">Zrozumiesz, co naprawdę decyduje o kosztach budowy</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-amber-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path>
              </svg>
              <span class="text-slate-200">Zadasz wykonawcy właściwe pytania, zanim podpiszesz umowę</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-amber-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path>
              </svg>
              <span class="text-slate-200">Poznasz każdy etap — od działki, przez stan surowy, po odbiór</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-amber-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path>
              </svg>
              <span class="text-slate-200">Unikniesz błędów decyzyjnych, które kosztowały innych setki tysięcy</span>
            </li>
          </ul>
          <div class="flex flex-col sm:flex-row gap-4 items-start">
            <a
              href={salesUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-lg px-8 py-4 rounded-full transition-all shadow-lg hover:shadow-xl"
              data-fbq-event="AddToCart"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M6 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
                <path d="M17 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
                <path d="M17 17h-11v-14h-2"></path>
                <path d="M6 5l14 1l-1 7h-13"></path>
              </svg>
              Kup książkę — 119 zł
            </a>
            <a
              href="#co-zyskasz"
              class="text-slate-400 hover:text-amber-400 transition-colors text-sm py-4 underline underline-offset-4"
            >
              Zobacz, co w środku ↓
            </a>
          </div>
          <p class="text-sm text-slate-500 mt-3">Wysyłka od 4,90 zł • kurier DPD</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Anchor Navigation -->
  <BookNavigation />

  <!-- Co zyskasz -->
  <Features
    id="co-zyskasz"
    tagline="Zawartość"
    title="Co zyskasz dzięki książce"
    items={[
      {
        title: 'Pewność siebie w każdej decyzji budowlanej',
        description:
          'Zrozumiesz, dlaczego wykonawca proponuje dane rozwiązanie i czy jest ono optymalne. Będziesz rozmawiać z fachowcami jak równy z równym.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Oszczędność dziesiątek tysięcy złotych na unikniętych błędach',
        description:
          'Każdy błąd na budowie kosztuje — często dziesiątki tysięcy złotych. Książka pokazuje konkretne pułapki i jak ich uniknąć.',
        icon: 'tabler:currency-zloty',
      },
      {
        title: 'Spokojny sen przez cały okres budowy',
        description:
          'Gdy wiesz, co powinno się dziać na każdym etapie, przestajesz się bać niespodzianek. Kontrolujesz proces zamiast reagować na kryzysy.',
        icon: 'tabler:moon',
      },
      {
        title: 'Wiedzę, jak skutecznie komunikować się z wykonawcami',
        description:
          'Dowiesz się, jakie pytania zadawać, na co zwracać uwagę w umowach i jak egzekwować ustalenia bez konfliktów.',
        icon: 'tabler:messages',
      },
      {
        title: 'Plan działania na każdy etap — od pozwolenia po odbiór',
        description:
          'Książka prowadzi Cię krok po kroku przez cały proces. Nie musisz zgadywać, co dalej — masz gotową mapę.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Umiejętność rozpoznawania problemów zanim staną się kosztowne',
        description:
          'Nauczysz się wychwytywać nieprawidłowości na wczesnym etapie — zanim przerodzi się to w kosztowną naprawę.',
        icon: 'tabler:eye',
      },
      {
        title: 'Kontrolę nad terminem i budżetem inwestycji',
        description:
          'Poznasz sprawdzone metody planowania budowy i zarządzania budżetem, dzięki którym unikniesz typowego scenariusza: "dwa razy drożej i rok dłużej".',
        icon: 'tabler:chart-line',
      },
    ]}
  />

  <!-- PRICING CARD — dedykowana sekcja BEZ value stacking (debate C3) -->
  <section class="bg-gradient-to-br from-blue-600 to-blue-800 py-16 md:py-24" id="kup">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl p-8 md:p-12 relative overflow-hidden">
        <!-- Ribbon -->
        <div
          class="absolute top-0 right-0 bg-amber-500 text-slate-900 text-xs font-bold px-4 py-2 rounded-bl-xl uppercase tracking-wide"
        >
          Jedyny wariant
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
          <!-- LEFT: okładka -->
          <div class="flex justify-center">
            <Image
              src={bookCoverCta}
              alt="Okładka książki Od Marzenia Do Wprowadzenia"
              width={280}
              height={392}
              widths={[240, 280, 360]}
              sizes="280px"
              class="w-full max-w-[280px] h-auto rounded-lg shadow-xl"
              loading="lazy"
            />
          </div>

          <!-- RIGHT: pricing + bullets + CTA -->
          <div>
            <h2 class="font-display text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-1">
              Od Marzenia Do Wprowadzenia
            </h2>
            <p class="text-muted mb-6">Kompletny przewodnik budowy domu</p>

            <div class="mb-6">
              <p class="text-xs font-semibold uppercase tracking-wider text-muted mb-1">Twoja cena</p>
              <div class="text-6xl md:text-7xl font-bold text-primary dark:text-amber-400 font-display leading-none">
                119 zł
              </div>
            </div>

            <ul class="space-y-3 mb-8">
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 text-green-600 dark:text-green-400 mt-0.5 flex-shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  ></path>
                </svg>
                <span class="text-sm text-gray-800 dark:text-slate-200">
                  <strong>Książka papierowa — 608 stron, twarda oprawa</strong><br />
                  78 oryginalnych ilustracji (rysunki architektoniczne, schematy, przekroje)
                </span>
              </li>
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 text-green-600 dark:text-green-400 mt-0.5 flex-shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  ></path>
                </svg>
                <span class="text-sm text-gray-800 dark:text-slate-200">
                  <strong>Wysyłka od 4,90 zł — kurier DPD</strong><br />
                  Szybka dostawa na terenie całej Polski
                </span>
              </li>
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 text-green-600 dark:text-green-400 mt-0.5 flex-shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  ></path>
                </svg>
                <span class="text-sm text-gray-800 dark:text-slate-200">
                  <strong>Gotowa teraz</strong><br />
                  Zamówienie do 11:00 = wysyłka dziś
                </span>
              </li>
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 text-green-600 dark:text-green-400 mt-0.5 flex-shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  ></path>
                </svg>
                <span class="text-sm text-gray-800 dark:text-slate-200">
                  <strong>Ponad 2000 sprzedanych egzemplarzy</strong><br />
                  Sprawdzony przewodnik, polecany przez Extradom.pl
                </span>
              </li>
              <li class="flex items-start gap-3">
                <svg
                  class="w-5 h-5 text-green-600 dark:text-green-400 mt-0.5 flex-shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  ></path>
                </svg>
                <span class="text-sm text-gray-800 dark:text-slate-200">
                  <strong>Autor: 13 lat praktyki w budownictwie jednorodzinnym</strong><br />
                  Z własnej firmy 4izby.pl
                </span>
              </li>
            </ul>

            <a
              href={salesUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 w-full md:w-auto bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-xl px-10 py-5 rounded-full transition-all shadow-2xl hover:shadow-amber-300/40 mb-4"
              data-fbq-event="AddToCart"
            >
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M6 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
                <path d="M17 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
                <path d="M17 17h-11v-14h-2"></path>
                <path d="M6 5l14 1l-1 7h-13"></path>
              </svg>
              Kup książkę — 119 zł
            </a>
            <p class="text-xs text-muted">
              Konsultacja generalnego wykonawcy kosztuje 300–500 zł za godzinę. Ta książka to 13 lat praktyki za 119 zł.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dla kogo — portret Wojtka (P1: swap book spread → wojtek-dla-kogo) -->
  <section class="py-16 md:py-20 bg-blue-50 dark:bg-transparent">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-10 md:gap-14 items-center">
        <!-- LEFT: portret Wojtka z książką -->
        <div class="relative">
          <Image
            src={wojtekDlaKogoImg}
            alt="Wojciech Tracichleb — autor książki Od Marzenia Do Wprowadzenia"
            widths={[400, 768, 1200]}
            width={1200}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
            class="w-full h-auto rounded-lg"
          />
        </div>

        <!-- RIGHT: copy + items -->
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-2">Dla kogo</p>
          <h2 class="text-3xl font-bold mb-3 dark:text-white font-display">Dla kogo napisałem tę książkę</h2>
          <p class="text-lg text-muted mb-6">Ta książka zmieni Wasze podejście do budowy domu.</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"
                ><path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path></svg
              >
              <span class="text-base">Marzysz o własnym domu i myślisz o jego budowie</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"
                ><path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path></svg
              >
              <span class="text-base">Budujesz systemem gospodarczym i szukasz uporządkowanej wiedzy</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"
                ><path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path></svg
              >
              <span class="text-base">Zatrudniłeś generalnego wykonawcę, ale chcesz mieć kontrolę nad budową</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"
                ><path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path></svg
              >
              <span class="text-base">Rozważasz kupno od dewelopera, bo boisz się samodzielnej organizacji budowy</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"
                ><path
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                ></path></svg
              >
              <span class="text-base">Planujesz budowę za 2-3 lata i chcesz się odpowiednio przygotować</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Spis treści — akordeon -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16" id="spis-tresci">
    <div class="text-center mb-10">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary">Pełna zawartość</p>
      <h2 class="text-3xl md:text-4xl font-bold dark:text-white mt-2 font-display">Spis treści</h2>
      <p class="text-muted mt-3">Kliknij część, aby zobaczyć szczegóły</p>
    </div>

    <div class="space-y-3">
      <details
        class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden"
      >
        <summary
          class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-primary text-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
        >
          <span>Część 1 — Marzenie o własnym domu</span>
          <svg
            class="w-5 h-5 transform transition-transform group-open:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg
          >
        </summary>
        <ul class="px-6 pb-5 space-y-1 text-muted text-sm border-t border-gray-100 dark:border-gray-700 pt-4">
          <li>Kim jestem? Dwa słowa, zanim zaczniemy</li>
          <li>Pięć porad, jak czytać tę książkę, aby wykorzystać ją w pełni</li>
          <li>Czego pragniesz?</li>
