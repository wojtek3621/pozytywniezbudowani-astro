---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Features from '~/components/widgets/Features.astro';
import Image from '~/components/common/Image.astro';
import BookNavigation from '~/components/widgets/BookNavigation.astro';

import ksiazkaImg from '~/assets/images/site/ksiazka-hero.jpg';
import bookCoverCta from '~/assets/images/ksiazka/book-cover-cta.jpg';
import niezaleznieImg from '~/assets/images/site/niezaleznie-etapu-book-spread.jpg';

import interior01 from '~/assets/images/ksiazka/interior-01.jpg';
import interior02 from '~/assets/images/ksiazka/interior-02.jpg';
import interior03 from '~/assets/images/ksiazka/interior-03.jpg';
import interior04 from '~/assets/images/ksiazka/interior-04.jpg';
import interior05 from '~/assets/images/ksiazka/interior-05.jpg';
import interior06 from '~/assets/images/ksiazka/interior-06.jpg';
import interior07 from '~/assets/images/ksiazka/interior-07.jpg';
import interior08 from '~/assets/images/ksiazka/interior-08.jpg';

const metadata = {
  title: 'Książka — Od Marzenia Do Wprowadzenia',
  description:
    '600 stron praktycznej wiedzy o budowie domu jednorodzinnego. Książka Wojciecha Tracichleb — kompletny przewodnik dla inwestora.',
};

const interiorImages = [
  { src: interior01, alt: 'Rozkładówka książki 1' },
  { src: interior02, alt: 'Rozkładówka książki 2' },
  { src: interior03, alt: 'Rozkładówka książki 3' },
  { src: interior04, alt: 'Rozkładówka książki 4' },
  { src: interior05, alt: 'Rozkładówka książki 5' },
  { src: interior06, alt: 'Rozkładówka książki 6' },
  { src: interior07, alt: 'Rozkładówka książki 7' },
  { src: interior08, alt: 'Rozkładówka książki 8' },
];

const salesUrl = 'https://pozytywnie-zbudowani.salescrm.pl/cart/add_product/15603';
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Kup książkę — 119 zł',
        href: salesUrl,
        target: '_blank',
        icon: 'tabler:shopping-cart',
      },
    ]}
    image={{ src: ksiazkaImg, alt: 'Książka Od Marzenia Do Wprowadzenia — Wojciech Tracichleb' }}
  >
    <Fragment slot="title">
      Od Marzenia<br />
      <span class="text-accent dark:text-white">Do Wprowadzenia</span>
    </Fragment>

    <Fragment slot="subtitle">
      <strong>Twój przewodnik w drodze do własnego domu.</strong><br /><br />
      Aż 600 stron napisanych przystępnym językiem — od pierwszej myśli o budowie, przez wybór projektu i działki, finansowanie,
      budowę, aż po wykończenie wnętrz. Napisana przez praktyka z wieloletnim doświadczeniem jako generalny wykonawca.
    </Fragment>
  </Hero>

  <!-- Sticky Anchor Navigation -->
  <BookNavigation />

  <!-- Co zyskasz -->
  <Features
    id="co-zyskasz"
    tagline="Zawartość"
    title="Co zyskasz dzięki książce"
    items={[
      {
        title: 'Pewność siebie w każdej decyzji budowlanej',
        description:
          'Zrozumiesz, dlaczego wykonawca proponuje dane rozwiązanie i czy jest ono optymalne. Będziesz rozmawiać z fachowcami jak równy z równym.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Oszczędność dziesiątek tysięcy złotych na unikniętych błędach',
        description:
          'Każdy błąd na budowie kosztuje — często dziesiątki tysięcy złotych. Książka pokazuje konkretne pułapki i jak ich uniknąć.',
        icon: 'tabler:currency-zloty',
      },
      {
        title: 'Spokojny sen przez cały okres budowy',
        description:
          'Gdy wiesz, co powinno się dziać na każdym etapie, przestajesz się bać niespodzianek. Kontrolujesz proces zamiast reagować na kryzysy.',
        icon: 'tabler:moon',
      },
      {
        title: 'Wiedzę, jak skutecznie komunikować się z wykonawcami',
        description:
          'Dowiesz się, jakie pytania zadawać, na co zwracać uwagę w umowach i jak egzekwować ustalenia bez konfliktów.',
        icon: 'tabler:messages',
      },
      {
        title: 'Plan działania na każdy etap — od pozwolenia po odbiór',
        description:
          'Książka prowadzi Cię krok po kroku przez cały proces. Nie musisz zgadywać, co dalej — masz gotową mapę.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Umiejętność rozpoznawania problemów zanim staną się kosztowne',
        description:
          'Nauczysz się wychwytywać nieprawidłowości na wczesnym etapie — zanim przerodzi się to w kosztowną naprawę.',
        icon: 'tabler:eye',
      },
      {
        title: 'Kontrolę nad terminem i budżetem inwestycji',
        description:
          'Poznasz sprawdzone metody planowania budowy i zarządzania budżetem, dzięki którym unikniesz typowego scenariusza: "dwa razy drożej i rok dłużej".',
        icon: 'tabler:chart-line',
      },
    ]}
  />

  <!-- Mid-page CTA after Features -->
  <div class="relative not-prose">
    <div class="max-w-4xl mx-auto px-4 md:px-6 py-8 text-center">
      <p class="text-lg text-muted dark:text-slate-400 mb-5">
        Zamówienia złożone do godziny 11:00 wysyłamy tego samego dnia.
      </p>
      <a href={salesUrl} target="_blank" rel="noopener noreferrer" class="btn-primary inline-flex items-center">
        Zamów swój egzemplarz — 119 zł
      </a>
    </div>
  </div>

  <!-- Dla kogo — custom layout z YouTube -->
  <section class="py-16 md:py-20 bg-blue-50 dark:bg-transparent">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-10 md:gap-14 items-center">
        <!-- LEFT: Open book spread (rozkładówka z rysunkami architektonicznymi) -->
        <div class="relative">
          <Image
            src={niezaleznieImg}
            alt="Otwarta książka Od Marzenia Do Wprowadzenia — rozkładówka z rysunkami architektonicznymi"
            widths={[400, 768, 1200]}
            width={1200}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
            class="w-full h-auto"
          />
        </div>

        <!-- RIGHT: Copy + items -->
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-2">Dla kogo</p>
          <h2 class="text-3xl font-bold mb-3 dark:text-white font-display">
            Niezależnie od etapu, na którym jesteście
          </h2>
          <p class="text-lg text-muted mb-6">Ta książka zmieni Wasze podejście do budowy domu.</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span class="text-base">Marzysz o własnym domu i myślisz o jego budowie</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span class="text-base">Budujesz systemem gospodarczym i szukasz uporządkowanej wiedzy</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span class="text-base">Zatrudniłeś generalnego wykonawcę, ale chcesz mieć kontrolę nad budową</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span class="text-base">Rozważasz kupno od dewelopera, bo boisz się samodzielnej organizacji budowy</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
              <span class="text-base">Planujesz budowę za 2-3 lata i chcesz się odpowiednio przygotować</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Spis treści — akordeon -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16" id="spis-tresci">
    <div class="text-center mb-10">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary">Pełna zawartość</p>
      <h2 class="text-3xl md:text-4xl font-bold dark:text-white mt-2 font-display">Spis treści</h2>
      <p class="text-muted mt-3">Kliknij część, aby zobaczyć szczegóły</p>
    </div>

    <div class="space-y-3">
      <details class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
        <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-primary text-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
          <span>Część 1 — Marzenie o własnym domu</span>
          <svg class="w-5 h-5 transform transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <ul class="px-6 pb-5 space-y-1 text-muted text-sm border-t border-gray-100 dark:border-gray-700 pt-4">
          <li>Kim jestem? Dwa słowa, zanim zaczniemy</li>
          <li>Pięć porad, jak czytać tę książkę, aby wykorzystać ją w pełni</li>
          <li>Czego pragniesz?</li>
          <li>Finanse i historia miksera za 300 zł</li>
          <li>Wymarzony projekt</li>
          <li>Wymarzona działka</li>
        </ul>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
        <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-primary text-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
          <span>Część 2 — Planowanie budowy</span>
          <svg class="w-5 h-5 transform transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <ul class="px-6 pb-5 space-y-1 text-muted text-sm border-t border-gray-100 dark:border-gray-700 pt-4">
          <li>Twoja Drużyna Pierścienia</li>
          <li>Wybór technologii budowy</li>
          <li>Zakup działki</li>
          <li>Co jeśli nie umiesz znaleźć odpowiedniej działki?</li>
          <li>Ostateczny wybór projektu</li>
          <li>Pozwolenie na budowę</li>
          <li>Poziom zero budynku</li>
          <li>Kredyt hipoteczny</li>
          <li>Projekt wnętrz</li>
          <li>Kto to wybuduje i kiedy zacząć rozmawiać z wykonawcami?</li>
          <li>Ukryte pieniądze</li>
          <li>Polisa ubezpieczeniowa</li>
          <li>Ostatnie przygotowania</li>
        </ul>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
        <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-primary text-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
          <span>Część 3A — Od pustej działki do stanu surowego</span>
          <svg class="w-5 h-5 transform transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <ul class="px-6 pb-5 space-y-1 text-muted text-sm border-t border-gray-100 dark:border-gray-700 pt-4">
          <li>Wytyczenie przez geodetę</li>
          <li>Płyta fundamentowa czy ławy fundamentowe</li>
          <li>Kanalizacja i przelotki mediów</li>
          <li>Szalunki, chudy beton i zbrojenie</li>
          <li>Izolacja pionowa</li>
          <li>Ściany fundamentowe</li>
          <li>Murowanie ścian nośnych</li>
          <li>Elementy żelbetowe</li>
          <li>Konstrukcja dachu</li>
          <li>Pokrycia dachowe</li>
          <li>Ściany działowe</li>
        </ul>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
        <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-primary text-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
          <span>Część 3B — Do stanu deweloperskiego</span>
          <svg class="w-5 h-5 transform transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <ul class="px-6 pb-5 space-y-1 text-muted text-sm border-t border-gray-100 dark:border-gray-700 pt-4">
          <li>Stolarka otworowa — drzwi, okna, rolety, brama</li>
          <li>Przyłącza do budynku (woda, kanalizacja, gaz)</li>
          <li>Instalacja elektryczna</li>
          <li>Klimatyzacja</li>
          <li>Fotowoltaika</li>
          <li>Tynki maszynowe</li>
          <li>Rekuperacja — wentylacja z odzyskiem ciepła</li>
          <li>Instalacja wodno-kanalizacyjna</li>
          <li>Ogrzewanie — źródła ciepła i sposoby ogrzewania</li>
          <li>Wylewki podłogowe</li>
          <li>Sufity podwieszane i zabudowa poddasza</li>
          <li>Docieplenie elewacji</li>
        </ul>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
        <summary class="cursor-pointer px-6 py-5 flex items-center justify-between font-bold text-primary text-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
          <span>Część 4 — Wykańczanie domu, a nie inwestora</span>
          <svg class="w-5 h-5 transform transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="grid sm:grid-cols-2 gap-x-8 px-6 pb-5 border-t border-gray-100 dark:border-gray-700 pt-4">
          <ul class="space-y-1 text-muted text-sm">
            <li>Wykończenie łazienek</li>
            <li>Płytkowanie pozostałych podłóg</li>
            <li>Gładzie i malowanie</li>
            <li>Montaż klimatyzatorów</li>
            <li>Osprzęt elektryczny i oświetlenie</li>
            <li>Listwy przypodłogowe</li>
            <li>Zgłoszenie zakończenia prac w nadzorze</li>
          </ul>
          <ul class="space-y-1 text-muted text-sm">
            <li>Utwardzenie terenu wokół domu</li>
            <li>Automatyczne nawadnianie i roboty koszące</li>
            <li>Studnia głębinowa</li>
            <li>Zmiękczacz wody</li>
            <li>Basen w ogrodzie</li>
            <li>Smart home — inteligentne domy</li>
            <li>Instalacja alarmowa lub monitoring</li>
            <li>Ładowarka samochodów elektrycznych</li>
            <li>Kino domowe</li>
            <li>Centralny odkurzacz czy może robot</li>
          </ul>
        </div>
      </details>
    </div>
  </div>

  <!-- Wnętrze książki — galeria -->
  <section class="relative not-prose scroll-mt-[144px]" id="wnetrze-ksiazki">
    <div class="absolute inset-0 bg-blue-50 dark:bg-transparent pointer-events-none -z-[1]"></div>
    <div class="max-w-6xl mx-auto px-4 md:px-6 py-12 md:py-16">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold uppercase tracking-wider text-primary">Zajrzyj do środka</p>
        <h2 class="text-3xl font-bold dark:text-white mt-2 mb-3">Wnętrze książki</h2>
        <p class="text-muted max-w-2xl mx-auto">
          Przejrzyste ilustracje, czytelny układ i praktyczne wskazówki na każdej stronie. 600 stron w twardej
          oprawie — to książka, do której będziesz wracać na każdym etapie budowy.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {
          interiorImages.map((img, i) => (
            <button
              type="button"
              class="lightbox-trigger rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 bg-white dark:bg-gray-800 cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary"
              data-lightbox-index={i}
              aria-label={`Powiększ zdjęcie: ${img.alt}`}
            >
              <Image
                src={img.src}
                alt={img.alt}
                width={800}
                widths={[400, 800]}
                sizes="(max-width: 639px) 100vw, (max-width: 1023px) 50vw, 33vw"
                class="w-full h-auto"
                loading="lazy"
              />
            </button>
          ))
        }
      </div>

      <!-- Lightbox overlay -->
      <div
        id="lightbox"
        class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-4 cursor-zoom-out"
        role="dialog"
        aria-modal="true"
        aria-label="Powiększenie zdjęcia"
      >
        <button
          id="lightbox-close"
          type="button"
          class="absolute top-4 right-4 text-white/80 hover:text-white transition-colors"
          aria-label="Zamknij"
        >
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <button
          id="lightbox-prev"
          type="button"
          class="absolute left-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white transition-colors"
          aria-label="Poprzednie"
        >
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button
          id="lightbox-next"
          type="button"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-white/80 hover:text-white transition-colors"
          aria-label="Następne"
        >
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
        <img
          id="lightbox-img"
          src=""
          alt=""
          class="max-w-full max-h-full object-contain select-none"
        />
      </div>

      <script is:inline>
        (function() {
          const triggers = document.querySelectorAll('.lightbox-trigger');
          const lightbox = document.getElementById('lightbox');
          const lbImg = document.getElementById('lightbox-img');
          const lbClose = document.getElementById('lightbox-close');
          const lbPrev = document.getElementById('lightbox-prev');
          const lbNext = document.getElementById('lightbox-next');

          let current = 0;
          const items = [];

          triggers.forEach((btn, i) => {
            const img = btn.querySelector('img');
            if (img) {
              items.push({ src: img.src, srcset: img.srcset || '', alt: img.alt });
            }
            btn.addEventListener('click', () => open(i));
          });

          function open(i) {
            current = i;
            const item = items[current];
            if (!item) return;
            lbImg.src = item.src;
            lbImg.srcset = item.srcset;
            lbImg.alt = item.alt;
            lightbox.classList.remove('hidden');
            lightbox.classList.add('flex');
            document.body.style.overflow = 'hidden';
          }

          function close() {
            lightbox.classList.add('hidden');
            lightbox.classList.remove('flex');
            document.body.style.overflow = '';
          }

          function prev(e) {
            e && e.stopPropagation();
            current = (current - 1 + items.length) % items.length;
            open(current);
          }

          function next(e) {
            e && e.stopPropagation();
            current = (current + 1) % items.length;
            open(current);
          }

          lbClose.addEventListener('click', (e) => { e.stopPropagation(); close(); });
          lbPrev.addEventListener('click', prev);
          lbNext.addEventListener('click', next);
          lightbox.addEventListener('click', (e) => { if (e.target === lightbox || e.target === lbImg) close(); });

          document.addEventListener('keydown', (e) => {
            if (lightbox.classList.contains('hidden')) return;
            if (e.key === 'Escape') close();
            if (e.key === 'ArrowLeft') prev();
            if (e.key === 'ArrowRight') next();
