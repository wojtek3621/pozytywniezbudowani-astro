  <!-- Meta Pixel ViewContent (init + PageView handled by GTM site-wide) -->
  <script is:inline>
    // ViewContent for /ksiazka/ — fbq loaded by GTM, no duplicate init/PageView
    if (typeof fbq !== 'undefined') {
      fbq('track', 'ViewContent', {
        content_name: 'Od Marzenia Do Wprowadzenia',
        content_type: 'product',
        content_ids: ['book-od-marzenia'],
        value: 119.0,
        currency: 'PLN',
      });
    } else {
      // Fallback: wait for GTM to load fbq
      window.addEventListener('load', function() {
        if (typeof fbq !== 'undefined') {
          fbq('track', 'ViewContent', {
            content_name: 'Od Marzenia Do Wprowadzenia',
            content_type: 'product',
            content_ids: ['book-od-marzenia'],
            value: 119.0,
            currency: 'PLN',
          });
        }
      });
    }
  </script>

  <!-- AddToCart listeners + UTM whitelist forwarding (debate I6: whitelist, nie ślepo cały query string) -->
  <script is:inline>
    (function () {
      const ALLOWED_PARAMS = [
        'utm_source',
        'utm_medium',
        'utm_campaign',
        'utm_content',
        'utm_term',
        'fbclid',
        'gclid',
        'ref',
      ];

      // AddToCart event na wszystkich CTA z data-fbq-event="AddToCart"
      document.querySelectorAll('[data-fbq-event="AddToCart"]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          if (typeof fbq !== 'undefined') {
            fbq('track', 'AddToCart', {
              content_name: 'Od Marzenia Do Wprowadzenia',
              content_type: 'product',
              content_ids: ['book-od-marzenia'],
              value: 119.0,
              currency: 'PLN',
            });
          }
        });
      });

      // UTM whitelist forwarding do salescrm.pl
      document.querySelectorAll('a[href*="salescrm.pl"]').forEach(function (link) {
        try {
          const url = new URL(link.href);
          const params = new URLSearchParams(window.location.search);
          ALLOWED_PARAMS.forEach(function (key) {
            const val = params.get(key);
            if (val) url.searchParams.set(key, val);
          });
          link.href = url.toString();
        } catch {
          /* URL parse may fail for relative hrefs */
        }
      });
    })();
  </script>
</Layout>
