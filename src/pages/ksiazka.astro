    <a
      href={salesUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block w-full bg-slate-900 text-amber-400 font-bold text-center py-3 rounded-lg"
      data-fbq-event="AddToCart"
    >
      Kup książkę — 119 zł
    </a>
