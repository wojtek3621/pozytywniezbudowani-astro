---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features from '~/components/widgets/Features.astro';

import ksiazkaImg from '~/assets/images/site/ksiazka-hero.jpg';

const metadata = {
  title: 'Książka — Od Marzenia Do Wprowadzenia',
  description: 'Ponad 600 stron praktycznej wiedzy o budowie domu jednorodzinnego. Książka Wojciecha Tracichleb — kompletny przewodnik dla inwestora.',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Kup książkę',
        href: 'https://pozytywnie-zbudowani.salescrm.pl/cart/add_product/15603',
        target: '_blank',
        icon: 'tabler:shopping-cart',
      },
    ]}
    image={{ src: ksiazkaImg, alt: 'Książka Od Marzenia Do Wprowadzenia — Wojciech Tracichleb' }}
  >
    <Fragment slot="title">
      Od Marzenia<br />
      <span class="text-accent dark:text-white">Do Wprowadzenia</span>
    </Fragment>

    <Fragment slot="subtitle">
      <strong>Twój przewodnik w drodze do własnego domu.</strong><br /><br />
      Książka prowadzi Was przez wszystkie etapy budowy domu — od pierwszej myśli „Może wybudujemy własny dom?",
      przez wybór projektu i działki, pozyskanie finansowania, budowę, aż po wykończenie wnętrz.
      Napisałem ją z myślą o tym, aby stała się kompleksowym przewodnikiem po całym procesie budowlanym.
    </Fragment>
  </Hero>

  <!-- Co zyskasz -->
  <Features
    id="co-zyskasz"
    tagline="Zawartość"
    title="Co zyskasz dzięki książce"
    items={[
      {
        title: 'Pewność siebie w każdej decyzji budowlanej',
        description: '',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Oszczędność dziesiątek tysięcy złotych na unikniętych błędach',
        description: '',
        icon: 'tabler:currency-zloty',
      },
      {
        title: 'Spokojny sen przez cały okres budowy',
        description: '',
        icon: 'tabler:moon',
      },
      {
        title: 'Wiedzę, jak skutecznie komunikować się z wykonawcami',
        description: '',
        icon: 'tabler:messages',
      },
      {
        title: 'Plan działania na każdy etap — od pozwolenia po odbiór',
        description: '',
        icon: 'tabler:list-check',
      },
      {
        title: 'Umiejętność rozpoznawania problemów zanim staną się kosztowne',
        description: '',
        icon: 'tabler:eye',
      },
    ]}
  />

  <!-- Dla kogo -->
  <Content
    isReversed
    tagline="Dla kogo"
    title="Dla kogo powstała ta książka"
    items={[
      {
        title: 'Marzycie o własnym domu, ale nie wiecie, od czego zacząć',
        description: '',
      },
      {
        title: 'Jesteście w trakcie budowy i potrzebujecie sprawdzonych rozwiązań',
        description: '',
      },
      {
        title: 'Wybraliście projekt i planujecie start',
        description: '',
      },
      {
        title: 'Chcecie uniknąć błędów, które kosztują dziesiątki tysięcy złotych',
        description: '',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Niezależnie od etapu, na którym jesteście
      </h3>
      Ta książka zmieni Wasze podejście do budowy domu.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Spis treści -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-3xl font-bold dark:text-white mb-8 text-center">Spis treści</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <h3 class="font-bold text-primary text-lg mb-2">Część 1</h3>
        <p class="text-muted">Marzenie o własnym domu</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <h3 class="font-bold text-primary text-lg mb-2">Część 2</h3>
        <p class="text-muted">Planowanie budowy własnego domu</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <h3 class="font-bold text-primary text-lg mb-2">Część 3A</h3>
        <p class="text-muted">Od pustej działki do stanu surowego otwartego</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <h3 class="font-bold text-primary text-lg mb-2">Część 3B</h3>
        <p class="text-muted">Od stanu surowego otwartego do stanu deweloperskiego</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 md:col-span-2">
        <h3 class="font-bold text-primary text-lg mb-2">Część 4</h3>
        <p class="text-muted">Wykańczanie domu, a nie inwestora</p>
      </div>
    </div>
    <p class="text-sm text-muted text-center mt-4">Zamówienia złożone do godziny 11:00 zostają wysłane tego samego dnia.</p>
  </div>

  <!-- O autorze -->
  <Content
    isAfterContent
    id="o-autorze"
    tagline="O autorze"
    title="Wojciech Tracichleb"
    items={[
      {
        title: 'Przedsiębiorca budowlany z pasją do przekazywania wiedzy',
        description: 'Od 2013 roku specjalizuje się wyłącznie w budownictwie jednorodzinnym. Uczestnicząc w powstawaniu kilkuset takich budynków poznał proces budowlany z każdej możliwej perspektywy.',
      },
      {
        title: 'Generalny wykonawca',
        description: 'Na co dzień prowadzi firmę budowlaną 4izby.pl i jako generalny wykonawca realizuje budowy domów jednorodzinnych.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Recenzje -->
  <Testimonials
    title="Co mówią recenzenci"
    testimonials={[
      {
        testimonial: '„Ta książka powinna być dołączana do każdego pozwolenia na budowę." „Od marzenia do wprowadzenia" to lektura, która realnie pomaga odnaleźć się w procesie budowy domu. Dzięki niej łatwiej podjąć decyzje – zarówno te oczywiste, jak i te mniej dostrzegalne, które mogą zaważyć nie tylko na kosztach, ale i na komforcie życia w przyszłym domu.',
        name: 'Daria Bućko',
        job: 'Extradom.pl',
      },
      {
        testimonial: 'Jak bardzo chciałabym przeczytać tę książkę osiem lat temu! Książka Wojciecha Tracichleba to esencja wiedzy i doświadczenia, jakie autor zdobył, pracując jako generalny wykonawca. Na kilkuset stronach nie tylko wyjaśnia kolejne etapy budowy, ale co najważniejsze – dzieli się praktycznymi wskazówkami.',
        name: 'Joanna Pachałko',
        job: 'Czytelniczka',
      },
      {
        testimonial: 'Najbardziej w książce cenię nie zwartą budowę treści czy wyszukane słownictwo, a autentyczność. Zawarte w niej informacje to nie zbitek frazesów czy danych wygrzebanych z internetu, a realne doświadczenie.',
        name: 'Aleksander Lipiński',
        job: 'Czytelnik',
      },
      {
        testimonial: 'Wiedza, jak to zwykle bywa, jest rozproszona i laikowi trudno ją zdobyć. Przecież nie ma podręcznika, który zbierałby wszystkie przydatne informacje w jednym miejscu. A właśnie — jest! To właśnie ta książka.',
        name: 'Mikołaj Bizoń',
        job: 'Czytelnik',
      },
      {
        testimonial: 'Autor operuje specjalistycznymi pojęciami w taki sposób, że wszystko szybko staje się dla czytelnika jasne. Tłumaczy nawet najprostsze elementy, ale — co ważne — nie znajdzie się tu choćby jednego zdania, z którego wypływałoby poczucie wyższości autora.',
        name: 'Klaudia Stryczyńska',
        job: 'Czytelniczka',
      },
      {
        testimonial: 'Po przeczytaniu tej książki pomimo mego doświadczenia w budownictwie doszedłem do wniosku, że jednak wciąż mało wiem i na niektóre rzeczy powinno się patrzeć zdecydowanie głębiej – tak jak robi to autor. Obowiązkowa pozycja na półkach każdego, kto postanowił spełnić swe marzenie o budowie własnego domu.',
        name: 'Norbert Mroczkowski',
        job: 'Czytelnik',
      },
    ]}
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Kup książkę — 119 zł',
        href: 'https://pozytywnie-zbudowani.salescrm.pl/cart/add_product/15603',
        target: '_blank',
        icon: 'tabler:shopping-cart',
      },
    ]}
  >
    <Fragment slot="title">
      Gotowi na budowę?
    </Fragment>

    <Fragment slot="subtitle">
      Ponad 600 stron wiedzy, która zaoszczędzi Wam tysięcy złotych i miesięcy stresu.
      Zacznijcie od solidnych podstaw.
    </Fragment>
  </CallToAction>
</Layout>
