---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Newsletter',
  description:
    'Dołącz do newslettera Pozytywnie Zbudowani – praktyczna wiedza o budowie domu prosto na Twoją skrzynkę.',
};
---

<Layout metadata={metadata}>
  <Hero tagline="Newsletter">
    <Fragment slot="title">
      Dołącz do <span class="text-accent dark:text-white">newslettera</span>
    </Fragment>

    <Fragment slot="subtitle">
      Regularnie dzielę się praktyczną wiedzą o budowie domu jednorodzinnego. Zapisz się, aby nie przegapić
      najważniejszych wskazówek – prosto na Twoją skrzynkę mailową.
    </Fragment>
  </Hero>

  <div class="max-w-xl mx-auto px-4 sm:px-6 py-12">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-8 border border-gray-100 dark:border-gray-700">
      <h2 class="text-xl font-bold dark:text-white mb-4 text-center">Zapisz się na newsletter</h2>
      <form id="nl-form" class="space-y-4" novalidate>
        <div>
          <label for="nl-email" class="block text-sm font-medium dark:text-gray-300 mb-1">Adres email</label>
          <input
            type="email"
            id="nl-email"
            name="email"
            required
            autocomplete="email"
            placeholder="Wpisz swój adres email"
            class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent text-base"
          />
        </div>
        <div class="flex items-start gap-2">
          <input type="checkbox" id="nl-zgoda" required class="mt-1" />
          <label for="nl-zgoda" class="text-sm text-muted" id="nl-zgoda-label">
            Wyrażam zgodę na otrzymywanie drogą elektroniczną informacji handlowej i marketingowej od Vultima sp. z o.o.
            (Pozytywnie Zbudowani). Zapoznałem/am się z
            <a href="/polityka-prywatnosci/" class="text-primary hover:underline">polityką prywatności</a>. Zgodę mogę
            wycofać w każdej chwili.
          </label>
        </div>
        <!-- Anti-bot (honeypot) -->
        <div class="hidden" aria-hidden="true">
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </div>
        <button
          type="submit"
          id="nl-submit"
          class="w-full px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-secondary transition-colors text-base"
        >
          Zapisz mnie do newslettera
        </button>
        <p id="nl-error" class="hidden text-sm text-red-600 text-center"></p>
      </form>
      <div id="nl-success" class="hidden text-center py-6">
        <svg class="w-12 h-12 text-green-600 mx-auto mb-3" fill="currentColor" viewBox="0 0 20 20">
          <path
            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
          ></path>
        </svg>
        <p class="font-bold dark:text-white mb-2">Jeszcze jeden krok – potwierdźcie zapis.</p>
        <p class="text-muted text-sm">
          Wysłałem Wam maila z linkiem potwierdzającym. Kliknijcie go, a dopiszę Was do listy. Bez tego kliknięcia nie
          wyślę Wam ani jednej wiadomości. Jeśli mail nie dotrze w kilka minut – zajrzyjcie do folderu SPAM lub Oferty.
        </p>
      </div>
      <p class="text-muted text-xs text-center mt-4">
        Zapis potwierdzacie kliknięciem w mailu (podwójne potwierdzenie). Wypisać się możecie jednym kliknięciem, z
        każdej wiadomości.
      </p>
    </div>
  </div>

  <script is:inline>
    (function () {
      const form = document.getElementById('nl-form');
      if (!form) return;
      const btn = document.getElementById('nl-submit');
      const errEl = document.getElementById('nl-error');
      const okEl = document.getElementById('nl-success');
      const labelEl = document.getElementById('nl-zgoda-label');

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        errEl.classList.add('hidden');
        const email = (document.getElementById('nl-email').value || '').trim();
        const consent = document.getElementById('nl-zgoda').checked;
        const honeypot = (form.querySelector('input[name="website"]') || {}).value || '';

        if (!email || email.indexOf('@') === -1) {
          errEl.textContent = 'Wpiszcie poprawny adres email.';
          errEl.classList.remove('hidden');
          return;
        }
        if (!consent) {
          errEl.textContent = 'Bez Waszej zgody nie mogę Was dopisać do listy.';
          errEl.classList.remove('hidden');
          return;
        }

        btn.disabled = true;
        btn.textContent = 'Zapisuję…';
        fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: email,
            consent: true,
            source: 'form_newsletter',
            website: honeypot,
            // Dokładna treść klauzuli, którą użytkownik miał przed oczami –
            // ląduje w consent logu jako dowód zgody.
            consent_text: (labelEl.textContent || '').replace(/\s+/g, ' ').trim(),
          }),
        })
          .then(function (res) {
            if (!res.ok) throw new Error('HTTP ' + res.status);
            return res.json();
          })
          .then(function () {
            form.classList.add('hidden');
            okEl.classList.remove('hidden');
          })
          .catch(function () {
            btn.disabled = false;
            btn.textContent = 'Zapisz mnie do newslettera';
            errEl.textContent = 'Coś poszło nie tak. Spróbujcie ponownie za chwilę.';
            errEl.classList.remove('hidden');
          });
      });
    })();
  </script>
</Layout>
