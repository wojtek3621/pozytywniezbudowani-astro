---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Kontakt',
  description: 'Skontaktuj się z Wojciechem Tracichleb — autorem Pozytywnie Zbudowani. Email, formularz kontaktowy.',
};
---

<Layout metadata={metadata}>
  <Hero tagline="Kontakt">
    <Fragment slot="title">
      <span class="text-accent dark:text-white">Kontakt</span>
    </Fragment>
  </Hero>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Dane kontaktowe -->
      <div>
        <div class="space-y-6">
          <div>
            <h3 class="font-bold dark:text-white text-lg mb-2">Vultima Sp. z o.o.</h3>
            <p class="text-muted">
              ul. Bolesława Chrobrego 3<br />
              42-690 Hanusek
            </p>
          </div>

          <div>
            <h3 class="font-bold dark:text-white text-lg mb-2">Email</h3>
            <p>
              <a href="mailto:kontakt@pozytywniezbudowani.pl" class="text-primary hover:underline"
                >kontakt@pozytywniezbudowani.pl</a
              >
            </p>
          </div>

          <div class="bg-blue-50 dark:bg-gray-800 rounded-lg p-4">
            <p class="text-muted text-sm">
              Z uwagi na napięty harmonogram nie prowadzę obecnie indywidualnych konsultacji. W pozostałych sprawach
              zachęcam do kontaktu mailowego lub przez poniższy formularz.
            </p>
          </div>

          <div>
            <h3 class="font-bold dark:text-white text-lg mb-2">Kontakt prasowy</h3>
            <p>
              <a href="mailto:pr@pozytywniezbudowani.pl" class="text-primary hover:underline"
                >pr@pozytywniezbudowani.pl</a
              >
            </p>
          </div>
        </div>
      </div>

      <!-- Formularz kontaktowy -->
      <div>
        <h2 class="text-2xl font-bold dark:text-white mb-6">Napisz do mnie</h2>
        <form action="https://formspree.io/f/mpqojwrz" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium dark:text-gray-300 mb-1">Imię i nazwisko</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium dark:text-gray-300 mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium dark:text-gray-300 mb-1">Wiadomość</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent"
            ></textarea>
          </div>
          <!-- Honeypot -->
          <div class="hidden">
            <input type="text" name="_gotcha" />
          </div>
          <div class="flex items-start gap-2">
            <input type="checkbox" id="zgoda" name="zgoda" required class="mt-1" />
            <label for="zgoda" class="text-sm text-muted">
              Wyrażam zgodę na przetwarzanie danych osobowych w celu odpowiedzi na moje zapytanie.
            </label>
          </div>
          <button
            type="submit"
            class="w-full px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-secondary transition-colors"
          >
            Wyślij
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
