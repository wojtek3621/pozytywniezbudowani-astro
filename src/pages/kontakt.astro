---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import ContactUs from '~/components/widgets/Contact.astro';

const metadata = {
  title: 'Kontakt',
  description: 'Skontaktuj sie z Wojciechem Tracichleb — autorem Pozytywnie Zbudowani. Email, telefon, formularz kontaktowy.',
};
---

<Layout metadata={metadata}>
  <Hero tagline="Kontakt">
    <Fragment slot="title">
      Skontaktuj sie <span class="text-accent dark:text-white">z nami</span>
    </Fragment>

    <Fragment slot="subtitle">
      Masz pytanie dotyczace budowy domu, ksiazki lub wspolpracy? Napisz — chetnie odpowiem.
    </Fragment>
  </Hero>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Dane kontaktowe -->
      <div>
        <h2 class="text-2xl font-bold dark:text-white mb-6">Dane kontaktowe</h2>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-primary/10 dark:bg-primary/20 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold dark:text-white">Email</h3>
              <a href="mailto:kontakt@pozytywniezbudowani.pl" class="text-primary hover:underline">kontakt@pozytywniezbudowani.pl</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-primary/10 dark:bg-primary/20 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold dark:text-white">Wspolpraca / media</h3>
              <a href="mailto:pr@pozytywniezbudowani.pl" class="text-primary hover:underline">pr@pozytywniezbudowani.pl</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 bg-primary/10 dark:bg-primary/20 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold dark:text-white">LinkedIn</h3>
              <a href="https://www.linkedin.com/in/wojciech-tracichleb/" target="_blank" rel="noopener" class="text-primary hover:underline">Wojciech Tracichleb</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Formularz kontaktowy -->
      <div>
        <h2 class="text-2xl font-bold dark:text-white mb-6">Napisz do mnie</h2>
        <form action="https://formspree.io/f/kontakt" method="POST" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium dark:text-gray-300 mb-1">Imie i nazwisko</label>
            <input type="text" id="name" name="name" required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium dark:text-gray-300 mb-1">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium dark:text-gray-300 mb-1">Wiadomosc</label>
            <textarea id="message" name="message" rows="5" required
              class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent"></textarea>
          </div>
          <!-- Honeypot -->
          <div class="hidden">
            <input type="text" name="_gotcha" />
          </div>
          <button type="submit"
            class="w-full px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-secondary transition-colors">
            Wyslij wiadomosc
          </button>
        </form>
        <p class="text-sm text-muted mt-3">
          Wyslanie formularza oznacza zgode na przetwarzanie danych osobowych w celu odpowiedzi na Twoje zapytanie.
        </p>
      </div>
    </div>
  </div>
</Layout>
