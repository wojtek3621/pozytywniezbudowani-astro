---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Test grafik — Niezależnie od etapu',
  ignoreTitleTemplate: true,
  description: 'Porównanie 3 wygenerowanych grafik dla sekcji /ksiazka/ Niezależnie od etapu',
  robots: { index: false, follow: false },
};

const options = [
  {
    id: 'A',
    slug: 'A-journey',
    title: 'A) Journey — książka z etapami budowy',
    description:
      'Otwarta książka z żółtą okładką, wewnątrz collage 6 zdjęć różnych etapów budowy (pusta działka, mur, dach, wykończenie, gotowy dom). Photorealistic. Dosłownie pokazuje "niezależnie od etapu" poprzez różne fazy budowy w jednej książce.',
    pros: [
      'Narrative match — książka pokazuje pełny flow, nie jeden moment',
      'Photorealistic, nie CGI',
      'Żółta okładka spójna z brandem',
      'Pokrywa wszystkie 5 segmentów audience',
    ],
    cons: ['Collage w środku książki może wyglądać nieco statycznie / catalog-like'],
    rating: '⭐ 9/10 — NAJLEPSZY (rekomendacja Artura)',
    isRecommended: true,
  },
  {
    id: 'B',
    slug: 'B-desk',
    title: 'B) Desk — home office planujący',
    description:
      'Cozy drewniane biurko z oknem. Otwarta książka z rzutem mieszkania, laptop ze szkicem domu, kubek kawy, okulary, mała roślina. Warm golden hour, soft daylight.',
    pros: [
      'Aspirational homeowner vibe',
      'Pasuje do segmentu "planuję za 2-3 lata"',
      'Cozy, warm aesthetic',
    ],
    cons: [
      'Pokazuje tylko 1 etap (planning), nie "wszystkie etapy"',
      'Za bardzo "office" — nie widać budowy',
    ],
    rating: '7/10',
    isRecommended: false,
  },
  {
    id: 'C',
    slug: 'C-popup',
    title: 'C) Pop-up — dom wyrastający z książki',
    description:
      'Kreatywna metafora — z otwartej książki "wyrasta" biała miniatura nowoczesnego domu 3D z małym drzewem, jak profesjonalna pop-up book. Aspirational magic.',
    pros: [
      'Wow factor, memorable, unikalny',
      'Silna metafora "z książki rodzi się dom"',
    ],
    cons: [
      'CGI vibe, nie photorealistic',
      'Dom wygląda za mały / dziecinny',
      'Może być odebrane jako zbyt kreatywne',
    ],
    rating: '6/10',
    isRecommended: false,
  },
  {
    id: 'D',
    slug: 'D-current-flatlay',
    title: 'D) Obecna (flat lay z narzędziami) — do porównania',
    description:
      'Flat lay top-down. Otwarta książka z żółtą okładką, wiertarka, rękawice, taśma, kawa, cegła, ołówek. Construction magazine vibe.',
    pros: ['Narzędzia sugerują praktyczność', 'Construction aesthetic'],
    cons: [
      'Za "bro construction" — nie trafia do 4/5 segmentów',
      'Narzędzia implikują "już jesteś na budowie"',
      'Marzyciele i planujący się nie utożsamią',
    ],
    rating: '5/10 — odrzucona przez Wojtka',
    isRecommended: false,
  },
];
---

<Layout metadata={metadata}>
  <section class="py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold uppercase tracking-wider text-primary mb-2">Test grafik</p>
        <h1 class="text-3xl md:text-4xl font-display font-bold mb-3">Niezależnie od etapu — 4 warianty</h1>
        <p class="text-muted max-w-2xl mx-auto">
          Sekcja na <code>/ksiazka/</code> w miejscu "Niezależnie od etapu, na którym jesteście". DALL-E 3, koszt $0.12 per grafika
          = <strong>$0.36 total za 3 nowe</strong> (D to obecna flatlay dla porównania).
        </p>
        <p class="text-muted mt-2">
          Rekomendacja Artura: <strong class="text-primary">A) Journey</strong> — zobacz uzasadnienie poniżej.
        </p>
      </div>

      <div class="space-y-12">
        {
          options.map((opt) => (
            <div class={`rounded-xl p-6 ${opt.isRecommended ? 'bg-blue-50 dark:bg-transparent border-2 border-primary' : 'bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700'} shadow-sm`}>
              <div class="flex items-start justify-between mb-3 gap-4 flex-wrap">
                <h2 class="text-xl md:text-2xl font-bold">{opt.title}</h2>
                <span class={`px-3 py-1 rounded-full text-sm font-semibold whitespace-nowrap ${opt.isRecommended ? 'bg-primary text-white' : 'bg-gray-100 dark:bg-gray-700 text-muted'}`}>
                  {opt.rating}
                </span>
              </div>
              <img
                src={`/test-grafiki/${opt.slug}.jpg`}
                alt={opt.title}
                class="w-full h-auto rounded-lg shadow-md mb-4"
                loading="lazy"
              />
              <p class="text-base text-muted mb-4">{opt.description}</p>
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <p class="text-sm font-semibold text-green-700 dark:text-green-400 mb-2">➕ PLUSY</p>
                  <ul class="text-sm text-muted space-y-1">
                    {opt.pros.map((p) => <li>• {p}</li>)}
                  </ul>
                </div>
                <div>
                  <p class="text-sm font-semibold text-red-700 dark:text-red-400 mb-2">➖ MINUSY</p>
                  <ul class="text-sm text-muted space-y-1">
                    {opt.cons.map((c) => <li>• {c}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="text-center mt-12 p-6 bg-gray-50 dark:bg-gray-800 rounded-xl">
        <p class="text-sm text-muted">
          Strona techniczna — robots noindex, tylko do oceny przez Wojtka.<br />
          Powiedz Arturowi "zatwierdzam A" (albo B/C) żeby wdrożyć wybraną.
        </p>
      </div>
    </div>
  </section>
</Layout>
