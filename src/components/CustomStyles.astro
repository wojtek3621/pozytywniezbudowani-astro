---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* PZ Brand Colors */
    --aw-color-primary: rgb(51 105 177);       /* #3369B1 — PZ niebieski */
    --aw-color-secondary: rgb(41 85 145);      /* ciemniejszy niebieski */
    --aw-color-accent: rgb(197 164 78);        /* #c5a44e — PZ zloty */

    --aw-color-text-heading: rgb(26 26 46);    /* #1a1a2e — ciemny */
    --aw-color-text-default: rgb(90 101 107);  /* #5A656B — PZ szary */
    --aw-color-text-muted: rgb(90 101 107 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(26 26 46);    /* #1a1a2e */

    ::selection {
      background-color: rgb(197 164 78 / 30%); /* zloty selection */
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* PZ Dark Mode */
    --aw-color-primary: rgb(197 164 78);       /* zloty jako primary w dark */
    --aw-color-secondary: rgb(51 105 177);     /* niebieski jako secondary */
    --aw-color-accent: rgb(220 190 110);       /* jasniejszy zloty */

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(26 26 46);

    ::selection {
      background-color: rgb(197 164 78 / 40%);
      color: snow;
    }
  }
</style>
