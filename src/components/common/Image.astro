---
import type { HTMLAttributes } from 'astro/types';
import { findImage } from '~/utils/images';
import {
  getImagesOptimized,
  astroAssetsOptimizer,
  unpicOptimizer,
  isUnpicCompatible,
  type ImageProps,
} from '~/utils/images-optimization';

// Priority prop — for LCP images. When true:
// - loading defaults to "eager" (not lazy)
// - fetchpriority="high" is added to <img>
// Use for hero/above-the-fold images. Reference: plans/active/2026-04-15-pz-astro-performance-ksiazka.md
type Props = ImageProps & { priority?: boolean };
type ImageType = {
  src: string;
  attributes: HTMLAttributes<'img'>;
};

const props = Astro.props;
const { priority, ...imageProps } = props;

if (imageProps.alt === undefined || imageProps.alt === null) {
  throw new Error();
}

if (typeof imageProps.width === 'string') {
  imageProps.width = parseInt(imageProps.width);
}

if (typeof imageProps.height === 'string') {
  imageProps.height = parseInt(imageProps.height);
}

// Priority images load eager by default, non-priority lazy
if (!imageProps.loading) {
  imageProps.loading = priority ? 'eager' : 'lazy';
}

if (!imageProps.decoding) {
  imageProps.decoding = priority ? 'sync' : 'async';
}

const _image = await findImage(imageProps.src);

let image: ImageType | undefined = undefined;

if (
  typeof _image === 'string' &&
  (_image.startsWith('http://') || _image.startsWith('https://')) &&
  isUnpicCompatible(_image)
) {
  image = await getImagesOptimized(_image, imageProps, unpicOptimizer);
} else if (_image) {
  image = await getImagesOptimized(_image, imageProps, astroAssetsOptimizer);
}
---

{
  !image ? (
    <Fragment />
  ) : priority ? (
    <img
      src={image.src}
      fetchpriority="high"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
      {...image.attributes}
    />
  ) : (
    <img src={image.src} crossorigin="anonymous" referrerpolicy="no-referrer" {...image.attributes} />
  )
}
