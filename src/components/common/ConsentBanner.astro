---
/**
 * GDPR Consent Banner — Google Consent Mode v2 Advanced
 *
 * Replaces CookieYes (850 PLN/year) with zero-cost, zero-dependency solution.
 * GTM loads BEFORE this with denied defaults → cookieless pings (Advanced mode).
 * Banner updates consent state on user interaction.
 *
 * Optimizations (2026-04-12 debate 4-model):
 * - No delay (instant render)
 * - Larger banner for higher engagement
 * - Footer link for consent withdrawal
 *
 * Update 2026-04-14 (owner directive):
 * - Removed "Tylko niezbędne" reject button (accept + settings only)
 * - Checkboxes pre-checked by default in settings panel
 * - User can still uncheck in settings before confirming
 *
 * Usage in Layout.astro:
 *   <ConsentBanner position="head" />  — in <head>, BEFORE Analytics/GTM
 *   <ConsentBanner position="body" />  — in <body>, visible banner + logic
 */

interface Props {
  position: 'head' | 'body';
}

const { position } = Astro.props;
---

{position === 'head' && (
  <script is:inline>
    // Google Consent Mode v2 Advanced — set defaults BEFORE GTM loads
    // GTM loads immediately after with these defaults → cookieless pings
    //
    // Codex fixes (2026-04-15 triple review):
    // - F7 HIGH: strict schema validation (prevents attacker consent injection)
    // - F8 HIGH: robust cookie parse (URL-encoded = in JSON value)
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    function isValidPzConsent(obj) {
      return obj
        && typeof obj === 'object'
        && typeof obj.analytics === 'boolean'
        && typeof obj.marketing === 'boolean';
    }

    (function() {
      var consent = null;
      try {
        // F8 fix: iterate cookies manually, use substring/indexOf (handles = in value)
        var parts = document.cookie ? document.cookie.split(';') : [];
        for (var i = 0; i < parts.length; i++) {
          var c = parts[i].trim();
          if (c.indexOf('pz_consent=') === 0) {
            var value = c.substring('pz_consent='.length);
            var parsed = JSON.parse(decodeURIComponent(value));
            // F7 fix: validate schema before trusting cookie
            if (isValidPzConsent(parsed)) consent = parsed;
            break;
          }
        }
      } catch(e) {}

      if (consent) {
        gtag('consent', 'default', {
          'analytics_storage': consent.analytics ? 'granted' : 'denied',
          'ad_storage': consent.marketing ? 'granted' : 'denied',
          'ad_user_data': consent.marketing ? 'granted' : 'denied',
          'ad_personalization': consent.marketing ? 'granted' : 'denied',
          'functionality_storage': 'granted',
          'security_storage': 'granted'
        });
      } else {
        gtag('consent', 'default', {
          'analytics_storage': 'denied',
          'ad_storage': 'denied',
          'ad_user_data': 'denied',
          'ad_personalization': 'denied',
          'functionality_storage': 'granted',
          'security_storage': 'granted',
          'wait_for_update': 500
        });
      }

      // TOR 2 telemetry hook — record consent_default_set_ms
      // Pasywne: tylko zapis, zero behavior change. Guard na existence of telemetry object
      // (scoped to /ksiazka* paths in PerfTelemetry.astro).
      if (window.__pzPerfTelemetry && window.__pzPerfTelemetry.timings) {
        window.__pzPerfTelemetry.timings.consent_default_set_ms = Math.round(performance.now());
      }
    })();
  </script>
)}

{position === 'body' && (
  <div id="pz-consent-banner" class="pz-banner pz-banner--hidden">
    <div class="pz-banner__inner">
      <div class="pz-banner__row">
        <div class="pz-banner__text">
          <p class="pz-banner__title">
            Ta strona u&#x17C;ywa plik&#xF3;w cookie
          </p>
          <p class="pz-banner__desc">
            Dzi&#x119;ki nim wiemy, jak korzystasz ze strony (analityka) i mo&#x17C;emy pokazywa&#x107; trafniejsze tre&#x15B;ci (marketing).
            Kliknij <strong class="pz-banner__strong">Akceptuj&#x119;</strong>, aby w pe&#x142;ni korzysta&#x107; z serwisu, lub dostosuj w ustawieniach.
          </p>
        </div>
        <div class="pz-banner__actions">
          <button id="pz-consent-accept" class="pz-banner__btn-accept" type="button">
            Akceptuj&#x119; wszystkie
          </button>
          <div class="pz-banner__settings-wrap">
            <button id="pz-consent-settings" class="pz-banner__btn-settings" type="button">
              Ustawienia
            </button>
          </div>
        </div>
      </div>

      <div id="pz-consent-details" class="pz-banner__details pz-banner__details--hidden">
        <p class="pz-banner__details-intro">Wybierz, na jakie kategorie wyra&#x17C;asz zgod&#x119;:</p>
        <label class="pz-banner__checkbox-row">
          <input type="checkbox" id="pz-consent-analytics" class="pz-banner__checkbox" checked />
          <div>
            <strong class="pz-banner__category-title">Analityka</strong>
            <span class="pz-banner__category-desc">Google Analytics &#x2014; jak u&#x17C;ytkownicy korzystaj&#x105; ze strony</span>
          </div>
        </label>
        <label class="pz-banner__checkbox-row">
          <input type="checkbox" id="pz-consent-marketing" class="pz-banner__checkbox" checked />
          <div>
            <strong class="pz-banner__category-title">Marketing</strong>
            <span class="pz-banner__category-desc">Meta Pixel, Google Ads &#x2014; trafniejsze reklamy i pomiar kampanii</span>
          </div>
        </label>
        <button id="pz-consent-save" class="pz-banner__btn-save" type="button">
          Potwierd&#x17A; wybory
        </button>
      </div>
    </div>
  </div>

  <style>
    /*
      PHASE 2 REFACTOR (2026-04-15):
      Inline styles → scoped <style> block.
      Static position:fixed + CSS class toggle (instead of style.display) eliminates forced reflow.
      Class-based hidden state prevents CLS when banner appears (out-of-flow, does not shift layout).
      Plan: plans/active/2026-04-15-pz-astro-performance-ksiazka.md (Faza 2.3)
    */
    .pz-banner {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 9999;
      background: rgba(26, 26, 46, 0.98);
      backdrop-filter: blur(20px);
      color: #fff;
      font-family: system-ui, -apple-system, sans-serif;
      box-shadow: 0 -12px 60px rgba(0, 0, 0, 0.4);
    }
    .pz-banner--hidden {
      display: none;
    }
    .pz-banner__inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 32px 32px 28px;
    }
    .pz-banner__row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px;
    }
    .pz-banner__text {
      flex: 1;
      min-width: 280px;
    }
    .pz-banner__title {
      margin: 0 0 6px;
      font-size: 22px;
      font-weight: 700;
      color: #fff;
      line-height: 1.35;
    }
    .pz-banner__desc {
      /* DB13 (Rounds 1) fix: #b8b8cc → #d4d4e0 for WCAG AA contrast on dark bg */
      margin: 0;
      color: #d4d4e0;
      font-size: 18px;
      line-height: 1.7;
    }
    .pz-banner__strong {
      color: #fff;
    }
    .pz-banner__actions {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      min-width: 200px;
    }
    .pz-banner__btn-accept {
      padding: 20px 44px;
      min-width: 240px;
      background: #c5a44e;
      color: #1a1a2e;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 19px;
      font-weight: 700;
      letter-spacing: 0.3px;
      transition: all 0.2s;
      box-shadow: 0 2px 8px rgba(197, 164, 78, 0.3);
    }
    .pz-banner__btn-accept:hover {
      background: #d4b35d;
      transform: translateY(-1px);
    }
    .pz-banner__settings-wrap {
      display: flex;
      justify-content: center;
    }
    .pz-banner__btn-settings {
      padding: 6px 12px;
      background: transparent;
      color: #c5a44e;
      border: none;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .pz-banner__details {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
    .pz-banner__details--hidden {
      display: none;
    }
    .pz-banner__details-intro {
      margin: 0 0 12px;
      font-size: 13px;
      color: #c4c4d8;
    }
    .pz-banner__checkbox-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
      cursor: pointer;
      padding: 8px 12px;
      background: rgba(255, 255, 255, 0.04);
      border-radius: 6px;
    }
    .pz-banner__checkbox {
      accent-color: #c5a44e;
      width: 18px;
      height: 18px;
    }
    .pz-banner__category-title {
      font-size: 14px;
    }
    .pz-banner__category-desc {
      display: block;
      font-size: 12px;
      color: #c4c4d8;
      margin-top: 2px;
    }
    .pz-banner__btn-save {
      margin-top: 8px;
      padding: 12px 24px;
      background: #c5a44e;
      color: #1a1a2e;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 600;
    }
  </style>

  <script is:inline>
    (function () {
      // F8 fix: robust cookie parse (URL-encoded = in JSON value, multiple cookies)
      function getConsent() {
        try {
          var parts = document.cookie ? document.cookie.split(';') : [];
          for (var i = 0; i < parts.length; i++) {
            var c = parts[i].trim();
            if (c.indexOf('pz_consent=') === 0) {
              var value = c.substring('pz_consent='.length);
              var parsed = JSON.parse(decodeURIComponent(value));
              // F7 fix: validate schema
              if (
                parsed &&
                typeof parsed === 'object' &&
                typeof parsed.analytics === 'boolean' &&
                typeof parsed.marketing === 'boolean'
              ) {
                return parsed;
              }
              return null;
            }
          }
        } catch (e) {}
        return null;
      }

      function setConsent(analytics, marketing) {
        var consent = { analytics: analytics, marketing: marketing, ts: Date.now() };
        var expires = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toUTCString();
        // F6 fix: add Secure flag (HTTPS-only cookie, prevents interception on plain HTTP)
        // Site is HTTPS-only (HSTS enforces) — Secure flag safe to add unconditionally
        document.cookie =
          'pz_consent=' +
          encodeURIComponent(JSON.stringify(consent)) +
          '; expires=' +
          expires +
          '; path=/; SameSite=Lax; Secure';

        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag('consent', 'update', {
          analytics_storage: analytics ? 'granted' : 'denied',
          ad_storage: marketing ? 'granted' : 'denied',
          ad_user_data: marketing ? 'granted' : 'denied',
          ad_personalization: marketing ? 'granted' : 'denied',
        });

        dataLayer.push({ event: 'cookie_consent_update' });

        // Phase 2 refactor: use CSS class instead of style.display (no forced reflow)
        var banner = document.getElementById('pz-consent-banner');
        if (banner) banner.classList.add('pz-banner--hidden');
      }

      function showBanner() {
        if (!getConsent()) {
          var banner = document.getElementById('pz-consent-banner');
          // Phase 2 refactor: remove class instead of style.display='block'
          if (banner) banner.classList.remove('pz-banner--hidden');
        }
      }

      function bindEvents() {
        var acceptBtn = document.getElementById('pz-consent-accept');
        var settingsBtn = document.getElementById('pz-consent-settings');
        var saveBtn = document.getElementById('pz-consent-save');
        var details = document.getElementById('pz-consent-details');

        if (acceptBtn)
          acceptBtn.onclick = function () {
            setConsent(true, true);
          };
        if (settingsBtn)
          settingsBtn.onclick = function () {
            // Phase 2 refactor: use CSS class for details toggle
            if (details) details.classList.toggle('pz-banner__details--hidden');
          };
        if (saveBtn)
          saveBtn.onclick = function () {
            var a = document.getElementById('pz-consent-analytics');
            var m = document.getElementById('pz-consent-marketing');
            setConsent(a ? a.checked : false, m ? m.checked : false);
          };

        // Hover effect is now pure CSS (:hover), JS hover handlers removed
      }

      showBanner();
      bindEvents();

      // Expose global API for footer "withdraw consent" link (Gemini review finding)
      // Usage: <a href="#" onclick="window.pzOpenConsent(); return false;">Zmień zgody</a>
      window.pzOpenConsent = function () {
        var banner = document.getElementById('pz-consent-banner');
        if (banner) banner.classList.remove('pz-banner--hidden');
      };

      // SPA navigation: re-show banner if no consent
      document.addEventListener('astro:page-load', function () {
        showBanner();
        bindEvents();
      });
    })();
  </script>
)}
