---
/**
 * GDPR Consent Banner — Google Consent Mode v2 Advanced
 *
 * Replaces CookieYes (850 PLN/year) with zero-cost, zero-dependency solution.
 * GTM loads BEFORE this with denied defaults → cookieless pings (Advanced mode).
 * Banner updates consent state on user interaction.
 *
 * Optimizations (2026-04-12 debate 4-model):
 * - No delay (instant render)
 * - Larger banner for higher engagement
 * - Footer link for consent withdrawal
 *
 * Update 2026-04-14 (owner directive):
 * - Removed "Tylko niezbędne" reject button (accept + settings only)
 * - Checkboxes pre-checked by default in settings panel
 * - User can still uncheck in settings before confirming
 *
 * Usage in Layout.astro:
 *   <ConsentBanner position="head" />  — in <head>, BEFORE Analytics/GTM
 *   <ConsentBanner position="body" />  — in <body>, visible banner + logic
 */

interface Props {
  position: 'head' | 'body';
}

const { position } = Astro.props;
---

{position === 'head' && (
  <script is:inline>
    // Google Consent Mode v2 Advanced — set defaults BEFORE GTM loads
    // GTM loads immediately after with these defaults → cookieless pings
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    (function() {
      var consent = null;
      try {
        var raw = document.cookie.split('; ').find(function(c){ return c.startsWith('pz_consent='); });
        if (raw) consent = JSON.parse(decodeURIComponent(raw.split('=')[1]));
      } catch(e) {}

      if (consent) {
        gtag('consent', 'default', {
          'analytics_storage': consent.analytics ? 'granted' : 'denied',
          'ad_storage': consent.marketing ? 'granted' : 'denied',
          'ad_user_data': consent.marketing ? 'granted' : 'denied',
          'ad_personalization': consent.marketing ? 'granted' : 'denied',
          'functionality_storage': 'granted',
          'security_storage': 'granted'
        });
      } else {
        gtag('consent', 'default', {
          'analytics_storage': 'denied',
          'ad_storage': 'denied',
          'ad_user_data': 'denied',
          'ad_personalization': 'denied',
          'functionality_storage': 'granted',
          'security_storage': 'granted',
          'wait_for_update': 500
        });
      }
    })();
  </script>
)}

{position === 'body' && (
  <div id="pz-consent-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:9999; background:rgba(26,26,46,0.98); backdrop-filter:blur(12px); color:#fff; font-family:system-ui,-apple-system,sans-serif; box-shadow:0 -8px 40px rgba(0,0,0,0.4);">
    <div style="max-width:1100px; margin:0 auto; padding:24px 24px 20px;">
      <div style="display:flex; flex-wrap:wrap; align-items:center; gap:16px;">
        <div style="flex:1; min-width:280px;">
          <p style="margin:0 0 6px; font-size:17px; font-weight:700; color:#fff; line-height:1.3;">
            Ta strona u&#x17C;ywa plik&#xF3;w cookie
          </p>
          <p style="margin:0; color:#b8b8cc; font-size:14px; line-height:1.6;">
            Dzi&#x119;ki nim wiemy, jak korzystasz ze strony (analityka) i mo&#x17C;emy pokazywa&#x107; trafniejsze tre&#x15B;ci (marketing).
            Kliknij <strong style="color:#e0e0f0;">Akceptuj&#x119;</strong>, aby w pe&#x142;ni korzysta&#x107; z serwisu, lub dostosuj w ustawieniach.
          </p>
        </div>
        <div style="display:flex; flex-direction:column; align-items:stretch; gap:8px; min-width:200px;">
          <button id="pz-consent-accept" style="padding:14px 32px; background:#c5a44e; color:#1a1a2e; border:none; border-radius:8px; cursor:pointer; font-size:15px; font-weight:700; letter-spacing:0.3px; transition:all 0.2s; box-shadow:0 2px 8px rgba(197,164,78,0.3);">
            Akceptuj&#x119; wszystkie
          </button>
          <div style="display:flex; justify-content:center;">
            <button id="pz-consent-settings" style="padding:6px 12px; background:transparent; color:#c5a44e; border:none; cursor:pointer; font-size:13px; font-weight:500; text-decoration:underline; text-underline-offset:2px;">
              Ustawienia
            </button>
          </div>
        </div>
      </div>

      <div id="pz-consent-details" style="display:none; margin-top:16px; padding-top:16px; border-top:1px solid rgba(255,255,255,0.1);">
        <p style="margin:0 0 12px; font-size:13px; color:#9090a8;">Wybierz, na jakie kategorie wyra&#x17C;asz zgod&#x119;:</p>
        <label style="display:flex; align-items:center; gap:10px; margin-bottom:10px; cursor:pointer; padding:8px 12px; background:rgba(255,255,255,0.04); border-radius:6px;">
          <input type="checkbox" id="pz-consent-analytics" checked style="accent-color:#c5a44e; width:18px; height:18px;" />
          <div>
            <strong style="font-size:14px;">Analityka</strong>
            <span style="display:block; font-size:12px; color:#9090a8; margin-top:2px;">Google Analytics, Hotjar &#x2014; jak u&#x17C;ytkownicy korzystaj&#x105; ze strony</span>
          </div>
        </label>
        <label style="display:flex; align-items:center; gap:10px; margin-bottom:10px; cursor:pointer; padding:8px 12px; background:rgba(255,255,255,0.04); border-radius:6px;">
          <input type="checkbox" id="pz-consent-marketing" checked style="accent-color:#c5a44e; width:18px; height:18px;" />
          <div>
            <strong style="font-size:14px;">Marketing</strong>
            <span style="display:block; font-size:12px; color:#9090a8; margin-top:2px;">Meta Pixel, Google Ads &#x2014; trafniejsze reklamy i pomiar kampanii</span>
          </div>
        </label>
        <button id="pz-consent-save" style="margin-top:8px; padding:12px 24px; background:#c5a44e; color:#1a1a2e; border:none; border-radius:8px; cursor:pointer; font-size:14px; font-weight:600;">
          Potwierd&#x17A; wybory
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      function getConsent() {
        try {
          var raw = document.cookie.split('; ').find(function(c){ return c.startsWith('pz_consent='); });
          if (raw) return JSON.parse(decodeURIComponent(raw.split('=')[1]));
        } catch(e) {}
        return null;
      }

      function setConsent(analytics, marketing) {
        var consent = { analytics: analytics, marketing: marketing, ts: Date.now() };
        var expires = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toUTCString();
        document.cookie = 'pz_consent=' + encodeURIComponent(JSON.stringify(consent)) + '; expires=' + expires + '; path=/; SameSite=Lax';

        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('consent', 'update', {
          'analytics_storage': analytics ? 'granted' : 'denied',
          'ad_storage': marketing ? 'granted' : 'denied',
          'ad_user_data': marketing ? 'granted' : 'denied',
          'ad_personalization': marketing ? 'granted' : 'denied'
        });

        dataLayer.push({ event: 'cookie_consent_update' });

        var banner = document.getElementById('pz-consent-banner');
        if (banner) banner.style.display = 'none';
      }

      function showBanner() {
        if (!getConsent()) {
          var banner = document.getElementById('pz-consent-banner');
          if (banner) banner.style.display = 'block';
        }
      }

      function bindEvents() {
        var acceptBtn = document.getElementById('pz-consent-accept');
        var settingsBtn = document.getElementById('pz-consent-settings');
        var saveBtn = document.getElementById('pz-consent-save');
        var details = document.getElementById('pz-consent-details');

        if (acceptBtn) acceptBtn.onclick = function() { setConsent(true, true); };
        if (settingsBtn) settingsBtn.onclick = function() {
          if (details) details.style.display = details.style.display === 'none' ? 'block' : 'none';
        };
        if (saveBtn) saveBtn.onclick = function() {
          var a = document.getElementById('pz-consent-analytics');
          var m = document.getElementById('pz-consent-marketing');
          setConsent(a ? a.checked : false, m ? m.checked : false);
        };

        // Hover effect on accept button
        if (acceptBtn) {
          acceptBtn.onmouseenter = function() { this.style.background = '#d4b35d'; this.style.transform = 'translateY(-1px)'; };
          acceptBtn.onmouseleave = function() { this.style.background = '#c5a44e'; this.style.transform = 'none'; };
        }
      }

      showBanner();
      bindEvents();

      // SPA navigation: re-show banner if no consent
      document.addEventListener('astro:page-load', function() {
        showBanner();
        bindEvents();
      });
    })();
  </script>
)}
