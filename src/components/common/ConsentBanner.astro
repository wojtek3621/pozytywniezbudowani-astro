---
/**
 * GDPR Consent Banner — Google Consent Mode v2 Advanced
 *
 * Replaces CookieYes (850 PLN/year) with zero-cost, zero-dependency solution.
 * GTM loads BEFORE this with denied defaults → cookieless pings (Advanced mode).
 * Banner updates consent state on user interaction.
 *
 * Optimizations (2026-04-12 debate 4-model):
 * - No delay (instant render)
 * - Larger banner for higher engagement
 * - Footer link for consent withdrawal
 *
 * Update 2026-04-14 (owner directive):
 * - Removed "Tylko niezbędne" reject button (accept + settings only)
 * - Checkboxes pre-checked by default in settings panel
 * - User can still uncheck in settings before confirming
 *
 * Update 2026-07-14 (owner directive) — port z platforma.pozytywniezbudowani.pl:
 * - Bottom bar → blokujący modal (overlay + scroll lock): decyzja przed wejściem
 * - Treść neutralna (standardowa formuła + link do polityki) zamiast opisu celów
 * - Układ przycisków BEZ ZMIAN: "Akceptuję wszystkie" + "Ustawienia"
 * - Consent Mode Advanced (blok head) NIETKNIĘTY — zmiana czysto wizualna
 *
 * Usage in Layout.astro:
 *   <ConsentBanner position="head" />  — in <head>, BEFORE Analytics/GTM
 *   <ConsentBanner position="body" />  — in <body>, visible banner + logic
 */

interface Props {
  position: 'head' | 'body';
}

const { position } = Astro.props;
---

{position === 'head' && (
  <script is:inline>
    // Google Consent Mode v2 Advanced — set defaults BEFORE GTM loads
    // GTM loads immediately after with these defaults → cookieless pings
    //
    // Codex fixes (2026-04-15 triple review):
    // - F7 HIGH: strict schema validation (prevents attacker consent injection)
    // - F8 HIGH: robust cookie parse (URL-encoded = in JSON value)
    window.dataLayer = window.dataLayer || [];
    function gtag(...args) {
      dataLayer.push(args);
    }

    function isValidPzConsent(obj) {
      return obj
        && typeof obj === 'object'
        && typeof obj.analytics === 'boolean'
        && typeof obj.marketing === 'boolean';
    }

    (function() {
      let consent = null;
      try {
        // F8 fix: iterate cookies manually, use substring/indexOf (handles = in value)
        const parts = document.cookie ? document.cookie.split(';') : [];
        for (let i = 0; i < parts.length; i++) {
          const c = parts[i].trim();
          if (c.indexOf('pz_consent=') === 0) {
            const value = c.substring('pz_consent='.length);
            const parsed = JSON.parse(decodeURIComponent(value));
            // F7 fix: validate schema before trusting cookie
            if (isValidPzConsent(parsed)) consent = parsed;
            break;
          }
        }
      } catch { /* ignore cookie parse errors — treat as no consent */ }

      if (consent) {
        gtag('consent', 'default', {
          'analytics_storage': consent.analytics ? 'granted' : 'denied',
          'ad_storage': consent.marketing ? 'granted' : 'denied',
          'ad_user_data': consent.marketing ? 'granted' : 'denied',
          'ad_personalization': consent.marketing ? 'granted' : 'denied',
          'functionality_storage': 'granted',
          'security_storage': 'granted'
        });
      } else {
        gtag('consent', 'default', {
          'analytics_storage': 'denied',
          'ad_storage': 'denied',
          'ad_user_data': 'denied',
          'ad_personalization': 'denied',
          'functionality_storage': 'granted',
          'security_storage': 'granted',
          'wait_for_update': 500
        });
      }

      // TOR 2 telemetry hook — record consent_default_set_ms
      // Pasywne: tylko zapis, zero behavior change. Guard na existence of telemetry object
      // (scoped to /ksiazka* paths in PerfTelemetry.astro).
      if (window.__pzPerfTelemetry && window.__pzPerfTelemetry.timings) {
        window.__pzPerfTelemetry.timings.consent_default_set_ms = Math.round(performance.now());
      }
    })();
  </script>
)}

{position === 'body' && (
  <div id="pz-consent-banner" class="pz-banner pz-banner--hidden">
    <div class="pz-banner__inner" role="dialog" aria-modal="true" aria-labelledby="pz-consent-title">
      <button
        id="pz-consent-close"
        class="pz-banner__btn-close pz-banner__btn-close--hidden"
        type="button"
        aria-label="Zamknij"
      >
        ×
      </button>

      <p class="pz-banner__title" id="pz-consent-title">Pliki cookie</p>
      <p class="pz-banner__desc">
        Ta strona — jak większość serwisów w sieci — korzysta z plików cookie. Szczegóły opisaliśmy w
        <a class="pz-banner__link" href="/polityka-prywatnosci/" target="_blank" rel="noopener">polityce prywatności</a>.
      </p>

      <div class="pz-banner__actions">
        <button id="pz-consent-accept" class="pz-banner__btn-accept" type="button"> Akceptuję wszystkie </button>
        <div class="pz-banner__settings-wrap">
          <button id="pz-consent-settings" class="pz-banner__btn-settings" type="button"> Ustawienia </button>
        </div>
      </div>

      <div id="pz-consent-details" class="pz-banner__details pz-banner__details--hidden">
        <p class="pz-banner__details-intro">Wybierz, na jakie kategorie wyrażasz zgodę:</p>
        <label class="pz-banner__checkbox-row">
          <input type="checkbox" id="pz-consent-analytics" class="pz-banner__checkbox" checked />
          <div>
            <strong class="pz-banner__category-title">Analityka</strong>
            <span class="pz-banner__category-desc">Google Analytics — jak użytkownicy korzystają ze strony</span>
          </div>
        </label>
        <label class="pz-banner__checkbox-row">
          <input type="checkbox" id="pz-consent-marketing" class="pz-banner__checkbox" checked />
          <div>
            <strong class="pz-banner__category-title">Marketing</strong>
            <span class="pz-banner__category-desc">Meta Pixel, Google Ads — trafniejsze reklamy i pomiar kampanii</span>
          </div>
        </label>
        <button id="pz-consent-save" class="pz-banner__btn-save" type="button"> Potwierdź wybory </button>
      </div>
    </div>
  </div>

  <style>
    /*
      PHASE 2 REFACTOR (2026-04-15):
      Inline styles → scoped <style> block.
      Static position:fixed + CSS class toggle (instead of style.display) eliminates forced reflow.
      Class-based hidden state prevents CLS when banner appears (out-of-flow, does not shift layout).
      Plan: plans/active/2026-04-15-pz-astro-performance-ksiazka.md (Faza 2.3)
    */
    /*
      MODAL REFACTOR (2026-07-14, owner directive):
      Bottom bar → centered dialog + overlay + scroll lock. Decyzja wymuszona
      przed wejściem (wyższa klikalność). Klasy BEM i ID bez zmian — logika
      consent (F6/F7/F8, Consent Mode Advanced) nietknięta.
    */
    .pz-banner {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(10, 10, 20, 0.72);
      backdrop-filter: blur(6px);
      color: #fff;
      font-family: system-ui, -apple-system, sans-serif;
    }
    .pz-banner.pz-banner--hidden {
      display: none;
    }
    /*
      Scroll lock. UWAGA: ten <style> siedzi wewnątrz wyrażenia {position === 'body' && (...)},
      więc Astro NIE kompiluje go jako scoped (brak data-astro-cid na .pz-banner) — reguły są
      globalne, a `:global()` wyciekłoby DOSŁOWNIE do outputu i zostało zignorowane przez
      przeglądarkę (złapane smoke testem 2026-07-14). Dlatego selektory wprost, bez :global().
    */
    html.pz-consent-open,
    body.pz-consent-open {
      overflow: hidden;
    }
    .pz-banner__inner {
      position: relative;
      width: 100%;
      max-width: 560px;
      max-height: 88vh;
      overflow-y: auto;
      background: #1a1a2e;
      border: 1px solid rgba(197, 164, 78, 0.28);
      border-radius: 16px;
      padding: 36px 34px 30px;
      box-shadow: 0 30px 90px rgba(0, 0, 0, 0.6);
      animation: pz-banner-in 0.3s ease-out;
    }
    @keyframes pz-banner-in {
      from {
        opacity: 0;
        transform: translateY(18px) scale(0.96);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    .pz-banner__title {
      margin: 0 0 10px;
      font-size: 24px;
      font-weight: 700;
      color: #fff;
      line-height: 1.3;
    }
    .pz-banner__desc {
      /* DB13 (Rounds 1) fix: #b8b8cc → #d4d4e0 for WCAG AA contrast on dark bg */
      margin: 0;
      color: #d4d4e0;
      font-size: 16px;
      line-height: 1.65;
    }
    .pz-banner__link {
      color: #c5a44e;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .pz-banner__btn-close {
      position: absolute;
      top: 10px;
      right: 12px;
      width: 34px;
      height: 34px;
      background: transparent;
      border: none;
      color: #9a9ab0;
      font-size: 22px;
      line-height: 1;
      cursor: pointer;
      border-radius: 8px;
    }
    .pz-banner__btn-close:hover {
      color: #fff;
      background: rgba(255, 255, 255, 0.06);
    }
    .pz-banner__btn-close--hidden {
      display: none;
    }
    .pz-banner__actions {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      margin-top: 26px;
    }
    .pz-banner__btn-accept {
      width: 100%;
      padding: 17px 44px;
      background: #c5a44e;
      color: #1a1a2e;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-size: 17px;
      font-weight: 700;
      letter-spacing: 0.3px;
      transition: all 0.2s;
      box-shadow: 0 2px 8px rgba(197, 164, 78, 0.3);
    }
    .pz-banner__btn-accept:hover {
      background: #d4b35d;
      transform: translateY(-1px);
    }
    .pz-banner__settings-wrap {
      display: flex;
      justify-content: center;
    }
    .pz-banner__btn-settings {
      padding: 6px 12px;
      background: transparent;
      color: #9a9ab0;
      border: none;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .pz-banner__btn-settings:hover {
      color: #c5a44e;
    }
    .pz-banner__details {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
    .pz-banner__details--hidden {
      display: none;
    }
    .pz-banner__details-intro {
      margin: 0 0 12px;
      font-size: 13px;
      color: #c4c4d8;
    }
    .pz-banner__checkbox-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
      cursor: pointer;
      padding: 8px 12px;
      background: rgba(255, 255, 255, 0.04);
      border-radius: 6px;
    }
    .pz-banner__checkbox {
      accent-color: #c5a44e;
      width: 18px;
      height: 18px;
    }
    .pz-banner__category-title {
      font-size: 14px;
    }
    .pz-banner__category-desc {
      display: block;
      font-size: 12px;
      color: #c4c4d8;
      margin-top: 2px;
    }
    /* Outline — żeby w rozwiniętym panelu nie konkurował wizualnie z „Akceptuję wszystkie" */
    .pz-banner__btn-save {
      width: 100%;
      margin-top: 8px;
      padding: 12px 24px;
      background: transparent;
      color: #c5a44e;
      border: 1px solid rgba(197, 164, 78, 0.5);
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 600;
    }
    .pz-banner__btn-save:hover {
      background: rgba(197, 164, 78, 0.1);
    }
    @media (max-width: 560px) {
      .pz-banner__inner {
        padding: 30px 24px 24px;
      }
      .pz-banner__title {
        font-size: 21px;
      }
    }
  </style>

  <script is:inline>
    (function () {
      // F8 fix: robust cookie parse (URL-encoded = in JSON value, multiple cookies)
      function getConsent() {
        try {
          const parts = document.cookie ? document.cookie.split(';') : [];
          for (let i = 0; i < parts.length; i++) {
            const c = parts[i].trim();
            if (c.indexOf('pz_consent=') === 0) {
              const value = c.substring('pz_consent='.length);
              const parsed = JSON.parse(decodeURIComponent(value));
              // F7 fix: validate schema
              if (
                parsed &&
                typeof parsed === 'object' &&
                typeof parsed.analytics === 'boolean' &&
                typeof parsed.marketing === 'boolean'
              ) {
                return parsed;
              }
              return null;
            }
          }
        } catch { /* ignore cookie parse errors */ }
        return null;
      }

      function setConsent(analytics, marketing) {
        const consent = { analytics: analytics, marketing: marketing, ts: Date.now() };
        const expires = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toUTCString();
        // F6 fix: add Secure flag (HTTPS-only cookie, prevents interception on plain HTTP)
        // Site is HTTPS-only (HSTS enforces) — Secure flag safe to add unconditionally
        document.cookie =
          'pz_consent=' +
          encodeURIComponent(JSON.stringify(consent)) +
          '; expires=' +
          expires +
          '; path=/; SameSite=Lax; Secure';

        window.dataLayer = window.dataLayer || [];
        function gtag(...args) {
          dataLayer.push(args);
        }
        gtag('consent', 'update', {
          analytics_storage: analytics ? 'granted' : 'denied',
          ad_storage: marketing ? 'granted' : 'denied',
          ad_user_data: marketing ? 'granted' : 'denied',
          ad_personalization: marketing ? 'granted' : 'denied',
        });

        dataLayer.push({ event: 'cookie_consent_update' });

        hideBanner();
      }

      // Modal (2026-07-14): scroll lock — <html>/<body> blokowane na czas decyzji
      function lockScroll(on) {
        const root = document.documentElement;
        const body = document.body;
        if (on) {
          root.classList.add('pz-consent-open');
          if (body) body.classList.add('pz-consent-open');
        } else {
          root.classList.remove('pz-consent-open');
          if (body) body.classList.remove('pz-consent-open');
        }
      }

      function hideBanner() {
        // Phase 2 refactor: use CSS class instead of style.display (no forced reflow)
        const banner = document.getElementById('pz-consent-banner');
        if (banner) banner.classList.add('pz-banner--hidden');
        lockScroll(false);
      }

      // closable=true  → krzyżyk (wywołanie z pzOpenConsent, zgoda JEST już zapisana)
      // closable=false → pierwsza wizyta: decyzja wymuszona, brak wyjścia poza przyciskami
      function showBanner(closable) {
        const banner = document.getElementById('pz-consent-banner');
        if (!banner) return;

        const closeBtn = document.getElementById('pz-consent-close');
        if (closeBtn) closeBtn.classList.toggle('pz-banner__btn-close--hidden', !closable);

        // Checkboxy odzwierciedlają zapisany stan (przy ponownym otwarciu)
        const saved = getConsent();
        const a = document.getElementById('pz-consent-analytics');
        const m = document.getElementById('pz-consent-marketing');
        if (a) a.checked = saved ? saved.analytics : true;
        if (m) m.checked = saved ? saved.marketing : true;

        banner.classList.remove('pz-banner--hidden');
        lockScroll(true);
      }

      function showBannerIfNeeded() {
        if (!getConsent()) showBanner(false);
      }

      function bindEvents() {
        const acceptBtn = document.getElementById('pz-consent-accept');
        const settingsBtn = document.getElementById('pz-consent-settings');
        const saveBtn = document.getElementById('pz-consent-save');
        const closeBtn = document.getElementById('pz-consent-close');
        const details = document.getElementById('pz-consent-details');

        if (acceptBtn)
          acceptBtn.onclick = function () {
            setConsent(true, true);
          };
        if (settingsBtn)
          settingsBtn.onclick = function () {
            // Phase 2 refactor: use CSS class for details toggle
            if (details) details.classList.toggle('pz-banner__details--hidden');
          };
        if (saveBtn)
          saveBtn.onclick = function () {
            const a = document.getElementById('pz-consent-analytics');
            const m = document.getElementById('pz-consent-marketing');
            setConsent(a ? a.checked : false, m ? m.checked : false);
          };
        if (closeBtn) closeBtn.onclick = hideBanner;

        // Hover effect is now pure CSS (:hover), JS hover handlers removed
      }

      showBannerIfNeeded();
      bindEvents();

      // Expose global API for footer "withdraw consent" link (Gemini review finding)
      // Usage: <a href="#" onclick="window.pzOpenConsent(); return false;">Zmień zgody</a>
      window.pzOpenConsent = function () {
        showBanner(!!getConsent());
      };

      // SPA navigation: re-show banner if no consent
      document.addEventListener('astro:page-load', function () {
        showBannerIfNeeded();
        bindEvents();
      });
    })();
  </script>
)}
