---
import '~/assets/styles/tailwind.css';

import { I18N } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import PerfTelemetry from '~/components/common/PerfTelemetry.astro';
import Analytics from '~/components/common/Analytics.astro';
import Clarity from '~/components/common/Clarity.astro';
import ConsentBanner from '~/components/common/ConsentBanner.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />

    <!-- Performance: preconnect to external origins -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://app.visitortracking.com" />
    <!-- Zapis na listę idzie same-origin (Worker → /api/subscribe → VPS), więc żaden
         zewnętrzny host nie wymaga rozgrzewki DNS. MailerLite odpięty 2026-07-14. -->

    <!-- dataLayer queue – MUST be initialized BEFORE ConsentBanner and Analytics -->
    <!-- Reason: ConsentBanner head script pushes consent defaults; Analytics (lazy in Phase 2) -->
    <!-- replays consent state. Without early init, early events could be lost. -->
    <!-- Plan: plans/active/2026-04-15-pz-astro-performance-ksiazka.md (Faza 1, DB8) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
    </script>

    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <!-- TOR 2 RUM telemetry – scoped to /ksiazka*, MUST precede ConsentBanner + Analytics -->
    <!-- Records 9 timestamps, sends beacon on visibilitychange→hidden -->
    <!-- Plan: plans/active/2026-04-15-pz-real-user-timing-telemetry.md -->
    <PerfTelemetry />
    <ConsentBanner position="head" />
    <Analytics />
    <!-- Microsoft Clarity (heatmapy CRO książki) – renderuje się TYLKO gdy PUBLIC_CLARITY_ID
         ustawione w env buildu; consent-gated (analytics=true). Sprint 1 2026-07. -->
    <Clarity />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-PKRLVW2G"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >

    <slot />

    <ConsentBanner position="body" />
    <BasicScripts />

    <!-- Kolektor behawioralny first-party (misja „analityka-atrybucja" 2026-07-18) →
         same-origin POST /api/z (Worker → D1 → tracking.db). OSOBNY system od beaconu
         zgód (reguła A). Reguła B: dane wyłącznie na naszą infra, nic do zewnętrznych
         narzędzi — dlatego działa też przed zgodą. Non-blocking (defer, sendBeacon). -->
    <script src="/z.js" defer is:inline></script>
  </body>
</html>
